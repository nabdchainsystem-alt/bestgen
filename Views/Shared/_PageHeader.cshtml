@using System.Globalization
@model PageHeaderViewModel
@{
    var isArabic = CultureInfo.CurrentUICulture.Name.StartsWith("ar", StringComparison.OrdinalIgnoreCase);
    string T(string en, string ar) => isArabic ? ar : en;
}

<div class="page-header">
    <div>
        <h1>@Model.Title</h1>
        <p>@Model.Description</p>
    </div>
    @if (!string.IsNullOrWhiteSpace(Model.CreateAction) && !string.IsNullOrWhiteSpace(Model.CreateController))
    {
        <a class="btn btn-primary" asp-controller="@Model.CreateController" asp-action="@Model.CreateAction">
            <i class="bi bi-plus-lg"></i>
            <span>@(Model.CreateText ?? T("Add new", "إضافة جديد"))</span>
        </a>
    }
</div>

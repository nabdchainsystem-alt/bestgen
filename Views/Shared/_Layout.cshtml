@using System.Globalization
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    bool IsActive(params string[] controllers) =>
        controllers.Any(c => string.Equals(c, currentController, StringComparison.OrdinalIgnoreCase));
    string GroupClass(params string[] controllers) =>
        IsActive(controllers) ? "nav-group open" : "nav-group";
    string CollapseClass(params string[] controllers) =>
        IsActive(controllers) ? "nav-collapse show" : "nav-collapse";

    var culture = CultureInfo.CurrentUICulture.Name;
    var isArabic = culture.StartsWith("ar", StringComparison.OrdinalIgnoreCase);
    var dir = isArabic ? "rtl" : "ltr";
    var lang = isArabic ? "ar" : "en";
    var bootstrapHref = isArabic
        ? "https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css"
        : "https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css";

    string T(string en, string ar) => isArabic ? ar : en;

    var returnUrl = Context.Request.Path + Context.Request.QueryString;
    var nextCulture = isArabic ? "en-US" : "ar-SA";
    var nextCultureLabel = isArabic ? "English" : "العربية";

    string SectionLabel()
    {
        var c = currentController.ToLowerInvariant();
        if (c == "dashboard" || string.IsNullOrEmpty(c)) return T("Dashboard", "لوحة التحكم");
        if (new[] { "customers", "salesquotations", "salesinvoices", "salesreceipts", "salesrefundreceipts", "creditnotes", "deliverynotes", "salespricepolicies" }.Contains(c)) return T("Sales", "المبيعات");
        if (new[] { "suppliers", "purchaseorders", "purchaseinvoices", "supplierpayments", "purchaserefundreceipts", "debitnotes", "goodsreceipts", "purchasepricepolicies" }.Contains(c)) return T("Purchases", "المشتريات");
        if (new[] { "productcategories", "products", "warehouses", "inventorycounts", "stocktransfers" }.Contains(c)) return T("Inventory", "المنتجات والمخزون");
        if (new[] { "fixedassets", "assettags", "assetrentals" }.Contains(c)) return T("Fixed Assets", "الأصول الثابتة");
        if (new[] { "accounts", "journalentries", "generalreceipts", "openingbalances", "reportingdimensions", "cashboxes", "bankaccounts", "expenses" }.Contains(c)) return T("Accounting", "المحاسبة");
        if (new[] { "employees", "employeedocuments", "payrollentries", "employeedeductions", "employeebonuses", "employeeloans", "employeereceipts", "employeerequests" }.Contains(c)) return T("HR", "الموارد البشرية");
        if (c == "reports") return T("Reports", "التقارير");
        if (c == "settings") return T("Settings", "الإعدادات");
        return T("Workspace", "العمل");
    }

    var pageTitle = ViewData["Title"]?.ToString() ?? T("Dashboard", "لوحة التحكم");
    var sectionLabel = SectionLabel();

    var loginName = User?.Identity?.Name ?? "";
    var initials = string.IsNullOrWhiteSpace(loginName)
        ? "B"
        : loginName.Trim().Substring(0, 1).ToUpperInvariant();
    var profileRole = User != null && SignInManager.IsSignedIn(User)
        ? T("Account Owner", "مالك الحساب")
        : T("Guest session", "جلسة زائر");
}
<!DOCTYPE html>
<html lang="@lang" dir="@dir" data-culture="@culture">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle · Bestgen</title>
    <link rel="preconnect" href="https://cdn.jsdelivr.net" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/earlyaccess/droidarabickufi.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="@bootstrapHref" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <aside class="app-sidebar" id="appSidebar">
            <div class="brand">
                <div class="brand-card">
                    <div class="brand-mark">B</div>
                    <div class="brand-meta">
                        <div class="brand-label">@T("Workspace", "مساحة العمل")</div>
                        <div class="brand-title">Bestgen</div>
                    </div>
                </div>
            </div>

            <nav class="sidebar-nav">
                <a asp-controller="Dashboard" asp-action="Index" class="nav-link nav-item @(IsActive("Dashboard") ? "active" : "")">
                    <i class="bi bi-grid-1x2"></i><span>@T("Dashboard", "لوحة التحكم")</span>
                </a>

                @{ var salesActive = new[] { "Customers", "SalesQuotations", "SalesInvoices", "SalesReceipts", "SalesRefundReceipts", "CreditNotes", "DeliveryNotes", "SalesPricePolicies" }; }
                <details class="@GroupClass(salesActive)" @(IsActive(salesActive) ? "open" : "")>
                    <summary><i class="bi bi-cart-check"></i><span>@T("Sales", "المبيعات")</span><i class="bi bi-chevron-down chev"></i></summary>
                    <div class="@CollapseClass(salesActive)">
                        <a asp-controller="Customers" asp-action="Index" class="nav-sublink @(IsActive("Customers") ? "active" : "")">@T("Customers", "قائمة العملاء")</a>
                        <a asp-controller="SalesQuotations" asp-action="Index" class="nav-sublink @(IsActive("SalesQuotations") ? "active" : "")">@T("Quotations", "عروض الأسعار")</a>
                        <a asp-controller="SalesInvoices" asp-action="Index" class="nav-sublink @(IsActive("SalesInvoices") ? "active" : "")">@T("Sales Invoices", "فواتير المبيعات")</a>
                        <a asp-controller="SalesReceipts" asp-action="Index" class="nav-sublink @(IsActive("SalesReceipts") ? "active" : "")">@T("Sales Receipts", "إيصالات المبيعات")</a>
                        <a asp-controller="SalesRefundReceipts" asp-action="Index" class="nav-sublink @(IsActive("SalesRefundReceipts") ? "active" : "")">@T("Refund Receipts", "إيصالات الاسترداد")</a>
                        <a asp-controller="CreditNotes" asp-action="Index" class="nav-sublink @(IsActive("CreditNotes") ? "active" : "")">@T("Credit Notes", "الإشعارات الدائنة")</a>
                        <a asp-controller="DeliveryNotes" asp-action="Index" class="nav-sublink @(IsActive("DeliveryNotes") ? "active" : "")">@T("Delivery Notes", "سندات تسليم المبيعات")</a>
                        <a asp-controller="SalesPricePolicies" asp-action="Index" class="nav-sublink @(IsActive("SalesPricePolicies") ? "active" : "")">@T("Sales Pricing", "سياسات تسعير المبيعات")</a>
                    </div>
                </details>

                @{ var purchaseActive = new[] { "Suppliers", "PurchaseOrders", "PurchaseInvoices", "SupplierPayments", "PurchaseRefundReceipts", "DebitNotes", "GoodsReceipts", "PurchasePricePolicies" }; }
                <details class="@GroupClass(purchaseActive)" @(IsActive(purchaseActive) ? "open" : "")>
                    <summary><i class="bi bi-bag-check"></i><span>@T("Purchases", "المشتريات")</span><i class="bi bi-chevron-down chev"></i></summary>
                    <div class="@CollapseClass(purchaseActive)">
                        <a asp-controller="Suppliers" asp-action="Index" class="nav-sublink @(IsActive("Suppliers") ? "active" : "")">@T("Suppliers", "قائمة الموردين")</a>
                        <a asp-controller="PurchaseOrders" asp-action="Index" class="nav-sublink @(IsActive("PurchaseOrders") ? "active" : "")">@T("Purchase Orders", "طلبات الشراء")</a>
                        <a asp-controller="PurchaseInvoices" asp-action="Index" class="nav-sublink @(IsActive("PurchaseInvoices") ? "active" : "")">@T("Purchase Invoices", "فواتير المشتريات")</a>
                        <a asp-controller="SupplierPayments" asp-action="Index" class="nav-sublink @(IsActive("SupplierPayments") ? "active" : "")">@T("Supplier Payments", "إيصالات المشتريات")</a>
                        <a asp-controller="PurchaseRefundReceipts" asp-action="Index" class="nav-sublink @(IsActive("PurchaseRefundReceipts") ? "active" : "")">@T("Purchase Refunds", "إيصالات الاسترداد")</a>
                        <a asp-controller="DebitNotes" asp-action="Index" class="nav-sublink @(IsActive("DebitNotes") ? "active" : "")">@T("Debit Notes", "الإشعارات المدينة")</a>
                        <a asp-controller="GoodsReceipts" asp-action="Index" class="nav-sublink @(IsActive("GoodsReceipts") ? "active" : "")">@T("Goods Receipts", "سندات استلام المنتجات")</a>
                        <a asp-controller="PurchasePricePolicies" asp-action="Index" class="nav-sublink @(IsActive("PurchasePricePolicies") ? "active" : "")">@T("Purchase Pricing", "سياسة تسعير الشراء")</a>
                    </div>
                </details>

                @{ var inventoryActive = new[] { "ProductCategories", "Products", "Warehouses", "InventoryCounts", "StockTransfers" }; }
                <details class="@GroupClass(inventoryActive)" @(IsActive(inventoryActive) ? "open" : "")>
                    <summary><i class="bi bi-box-seam"></i><span>@T("Products & Inventory", "المنتجات والمخزون")</span><i class="bi bi-chevron-down chev"></i></summary>
                    <div class="@CollapseClass(inventoryActive)">
                        <a asp-controller="ProductCategories" asp-action="Index" class="nav-sublink @(IsActive("ProductCategories") ? "active" : "")">@T("Product Categories", "أصناف المنتجات")</a>
                        <a asp-controller="Products" asp-action="Index" class="nav-sublink @(IsActive("Products") ? "active" : "")">@T("Products", "قائمة المنتجات")</a>
                        <a asp-controller="Warehouses" asp-action="Index" class="nav-sublink @(IsActive("Warehouses") ? "active" : "")">@T("Warehouses", "المخازن")</a>
                        <a asp-controller="InventoryCounts" asp-action="Index" class="nav-sublink @(IsActive("InventoryCounts") ? "active" : "")">@T("Inventory Counts", "عمليات الجرد")</a>
                        <a asp-controller="StockTransfers" asp-action="Index" class="nav-sublink @(IsActive("StockTransfers") ? "active" : "")">@T("Stock Transfers", "نقل المخزون")</a>
                    </div>
                </details>

                @{ var assetsActive = new[] { "FixedAssets", "AssetTags", "AssetRentals" }; }
                <details class="@GroupClass(assetsActive)" @(IsActive(assetsActive) ? "open" : "")>
                    <summary><i class="bi bi-buildings"></i><span>@T("Fixed Assets", "الأصول الثابتة")</span><i class="bi bi-chevron-down chev"></i></summary>
                    <div class="@CollapseClass(assetsActive)">
                        <a asp-controller="FixedAssets" asp-action="Index" class="nav-sublink @(IsActive("FixedAssets") ? "active" : "")">@T("Assets", "أصول")</a>
                        <a asp-controller="AssetTags" asp-action="Index" class="nav-sublink @(IsActive("AssetTags") ? "active" : "")">@T("Asset Tags", "وسوم الأصول")</a>
                        <a asp-controller="AssetRentals" asp-action="Index" class="nav-sublink @(IsActive("AssetRentals") ? "active" : "")">@T("Asset Rentals", "تأجيرات الأصول")</a>
                    </div>
                </details>

                @{ var accountingActive = new[] { "Accounts", "JournalEntries", "GeneralReceipts", "OpeningBalances", "ReportingDimensions", "CashBoxes", "BankAccounts", "Expenses" }; }
                <details class="@GroupClass(accountingActive)" @(IsActive(accountingActive) ? "open" : "")>
                    <summary><i class="bi bi-diagram-3"></i><span>@T("Advanced Accounting", "المحاسبة المتقدمة")</span><i class="bi bi-chevron-down chev"></i></summary>
                    <div class="@CollapseClass(accountingActive)">
                        <a asp-controller="Accounts" asp-action="Index" class="nav-sublink @(IsActive("Accounts") ? "active" : "")">@T("Chart of Accounts", "شجرة الحسابات")</a>
                        <a asp-controller="JournalEntries" asp-action="Index" class="nav-sublink @(IsActive("JournalEntries") ? "active" : "")">@T("Journal Entries", "القيود اليدوية")</a>
                        <a asp-controller="GeneralReceipts" asp-action="Index" class="nav-sublink @(IsActive("GeneralReceipts") ? "active" : "")">@T("General Receipts", "الإيصالات العامة")</a>
                        <a asp-controller="OpeningBalances" asp-action="Index" class="nav-sublink @(IsActive("OpeningBalances") ? "active" : "")">@T("Opening Balances", "الرصيد الافتتاحي")</a>
                        <a asp-controller="ReportingDimensions" asp-action="Index" class="nav-sublink @(IsActive("ReportingDimensions") ? "active" : "")">@T("Reporting Dimensions", "أبعاد التقارير")</a>
                        <a asp-controller="CashBoxes" asp-action="Index" class="nav-sublink @(IsActive("CashBoxes") ? "active" : "")">@T("Cash Boxes", "الصناديق النقدية")</a>
                        <a asp-controller="BankAccounts" asp-action="Index" class="nav-sublink @(IsActive("BankAccounts") ? "active" : "")">@T("Bank Accounts", "الحسابات البنكية")</a>
                        <a asp-controller="Expenses" asp-action="Index" class="nav-sublink @(IsActive("Expenses") ? "active" : "")">@T("Expenses", "المصروفات")</a>
                    </div>
                </details>

                @{ var hrActive = new[] { "Employees", "EmployeeDocuments", "PayrollEntries", "EmployeeDeductions", "EmployeeBonuses", "EmployeeLoans", "EmployeeReceipts", "EmployeeRequests" }; }
                <details class="@GroupClass(hrActive)" @(IsActive(hrActive) ? "open" : "")>
                    <summary><i class="bi bi-people"></i><span>@T("Human Resources", "الموارد البشرية")</span><i class="bi bi-chevron-down chev"></i></summary>
                    <div class="@CollapseClass(hrActive)">
                        <a asp-controller="Employees" asp-action="Index" class="nav-sublink @(IsActive("Employees") ? "active" : "")">@T("Employees", "الموظفين")</a>
                        <a asp-controller="EmployeeDocuments" asp-action="Index" class="nav-sublink @(IsActive("EmployeeDocuments") ? "active" : "")">@T("Employee Documents", "المستندات المرتبطة بالموظفين")</a>
                        <a asp-controller="PayrollEntries" asp-action="Index" class="nav-sublink @(IsActive("PayrollEntries") ? "active" : "")">@T("Payroll", "قيود الرواتب")</a>
                        <a asp-controller="EmployeeDeductions" asp-action="Index" class="nav-sublink @(IsActive("EmployeeDeductions") ? "active" : "")">@T("Deductions", "الخصومات")</a>
                        <a asp-controller="EmployeeBonuses" asp-action="Index" class="nav-sublink @(IsActive("EmployeeBonuses") ? "active" : "")">@T("Bonuses", "المكافآت")</a>
                        <a asp-controller="EmployeeLoans" asp-action="Index" class="nav-sublink @(IsActive("EmployeeLoans") ? "active" : "")">@T("Loans", "القروض")</a>
                        <a asp-controller="EmployeeReceipts" asp-action="Index" class="nav-sublink @(IsActive("EmployeeReceipts") ? "active" : "")">@T("Receipts", "الإيصالات")</a>
                        <a asp-controller="EmployeeRequests" asp-action="Index" class="nav-sublink @(IsActive("EmployeeRequests") ? "active" : "")">@T("Requests", "إدارة الطلبات")</a>
                    </div>
                </details>

                <a asp-controller="Reports" asp-action="Index" class="nav-link nav-item @(IsActive("Reports") ? "active" : "")">
                    <i class="bi bi-bar-chart-line"></i><span>@T("Reports", "التقارير")</span>
                </a>
                <a asp-controller="Settings" asp-action="Index" class="nav-link nav-item @(IsActive("Settings") ? "active" : "")">
                    <i class="bi bi-sliders2"></i><span>@T("Settings", "الإعدادات")</span>
                </a>
            </nav>

            <div class="sidebar-profile">
                <div class="sidebar-profile-card">
                    <div class="avatar">@initials</div>
                    <div class="sidebar-profile-meta">
                        <div class="sidebar-profile-name">@(string.IsNullOrWhiteSpace(loginName) ? T("Bestgen Studio", "بست جين") : loginName)</div>
                        <div class="sidebar-profile-role">@profileRole</div>
                    </div>
                </div>
            </div>
        </aside>

        <div class="app-main">
            <header class="topbar">
                <button class="icon-button" type="button" id="sidebarToggle" aria-label="@T("Toggle sidebar", "طي القائمة")">
                    <i class="bi bi-list"></i>
                </button>
                <div class="breadcrumb-trail">
                    <span class="breadcrumb-item-text">@sectionLabel</span>
                    <span class="breadcrumb-sep">/</span>
                    <span class="breadcrumb-item-text current">@pageTitle</span>
                </div>
                <div class="topbar-search">
                    <i class="bi bi-search"></i>
                    <input type="search" placeholder="@T("Quick search...", "بحث سريع في النظام...")" />
                </div>
                <div class="topbar-actions">
                    <a asp-controller="Language" asp-action="Set"
                       asp-route-culture="@nextCulture"
                       asp-route-returnUrl="@returnUrl"
                       class="chip-button" title="@T("Switch language", "تبديل اللغة")">
                        <i class="bi bi-translate"></i><span>@nextCultureLabel</span>
                    </a>
                    <button class="chip-button" type="button" id="themeToggle">
                        <i class="bi bi-moon-stars"></i><span>@T("Dark mode", "الوضع الداكن")</span>
                    </button>
                    <partial name="_LoginPartial" />
                </div>
            </header>

            <main class="content-wrap">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/echarts/echarts.min.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

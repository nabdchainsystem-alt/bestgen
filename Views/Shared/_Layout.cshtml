@using System.Globalization
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    bool IsActive(params string[] controllers) =>
        controllers.Any(c => string.Equals(c, currentController, StringComparison.OrdinalIgnoreCase));
    string GroupClass(params string[] controllers) =>
        IsActive(controllers) ? "nav-group open" : "nav-group";
    string CollapseClass(params string[] controllers) =>
        IsActive(controllers) ? "nav-collapse show" : "nav-collapse";

    var culture = CultureInfo.CurrentUICulture.Name;
    var isArabic = culture.StartsWith("ar", StringComparison.OrdinalIgnoreCase);
    var dir = isArabic ? "rtl" : "ltr";
    var lang = isArabic ? "ar" : "en";
    var bootstrapHref = isArabic
        ? "https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css"
        : "https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css";

    string T(string en, string ar) => isArabic ? ar : en;

    var returnUrl = Context.Request.Path + Context.Request.QueryString;
    var nextCulture = isArabic ? "en-US" : "ar-SA";
    var nextCultureLabel = isArabic ? "EN" : "AR";

    (string Section, string Page) Crumbs()
    {
        var c = currentController.ToLowerInvariant();
        if (c == "dashboard" || string.IsNullOrEmpty(c))
            return (T("Workspace", "مساحة العمل"), T("Dashboard", "لوحة التحكم"));

        var sales = new[] { "customers", "salesquotations", "salesinvoices", "salesreceipts", "salesrefundreceipts", "creditnotes", "deliverynotes", "salespricepolicies" };
        var purchases = new[] { "suppliers", "purchaseorders", "purchaseinvoices", "supplierpayments", "purchaserefundreceipts", "debitnotes", "goodsreceipts", "purchasepricepolicies" };
        var inventory = new[] { "productcategories", "products", "warehouses", "inventorycounts", "stocktransfers" };
        var assets = new[] { "fixedassets", "assettags", "assetrentals" };
        var accounting = new[] { "accounts", "journalentries", "generalreceipts", "openingbalances", "reportingdimensions", "cashboxes", "bankaccounts", "expenses" };
        var hr = new[] { "employees", "employeedocuments", "payrollentries", "employeedeductions", "employeebonuses", "employeeloans", "employeereceipts", "employeerequests" };

        string section;
        if (sales.Contains(c)) section = T("Sales", "المبيعات");
        else if (purchases.Contains(c)) section = T("Purchases", "المشتريات");
        else if (inventory.Contains(c)) section = T("Inventory", "المنتجات والمخزون");
        else if (assets.Contains(c)) section = T("Fixed Assets", "الأصول الثابتة");
        else if (accounting.Contains(c)) section = T("Accounting", "المحاسبة");
        else if (hr.Contains(c)) section = T("Human Resources", "الموارد البشرية");
        else if (c == "reports") section = T("Reports", "التقارير");
        else if (c == "settings") section = T("Settings", "الإعدادات");
        else if (c == "home") section = T("Home", "الرئيسية");
        else section = T("Workspace", "مساحة العمل");

        var page = c switch
        {
            "customers" => T("Customers", "قائمة العملاء"),
            "salesquotations" => T("Quotations", "عروض الأسعار"),
            "salesinvoices" => T("Sales Invoices", "فواتير المبيعات"),
            "salesreceipts" => T("Sales Receipts", "إيصالات المبيعات"),
            "salesrefundreceipts" => T("Refund Receipts", "إيصالات الاسترداد"),
            "creditnotes" => T("Credit Notes", "الإشعارات الدائنة"),
            "deliverynotes" => T("Delivery Notes", "سندات تسليم المبيعات"),
            "salespricepolicies" => T("Sales Pricing", "سياسات تسعير المبيعات"),
            "suppliers" => T("Suppliers", "قائمة الموردين"),
            "purchaseorders" => T("Purchase Orders", "طلبات الشراء"),
            "purchaseinvoices" => T("Purchase Invoices", "فواتير المشتريات"),
            "supplierpayments" => T("Supplier Payments", "إيصالات المشتريات"),
            "purchaserefundreceipts" => T("Purchase Refunds", "إيصالات الاسترداد"),
            "debitnotes" => T("Debit Notes", "الإشعارات المدينة"),
            "goodsreceipts" => T("Goods Receipts", "سندات استلام المنتجات"),
            "purchasepricepolicies" => T("Purchase Pricing", "سياسة تسعير الشراء"),
            "productcategories" => T("Product Categories", "أصناف المنتجات"),
            "products" => T("Products", "قائمة المنتجات"),
            "warehouses" => T("Warehouses", "المخازن"),
            "inventorycounts" => T("Inventory Counts", "عمليات الجرد"),
            "stocktransfers" => T("Stock Transfers", "نقل المخزون"),
            "fixedassets" => T("Assets", "أصول"),
            "assettags" => T("Asset Tags", "وسوم الأصول"),
            "assetrentals" => T("Asset Rentals", "تأجيرات الأصول"),
            "accounts" => T("Chart of Accounts", "شجرة الحسابات"),
            "journalentries" => T("Journal Entries", "القيود اليدوية"),
            "generalreceipts" => T("General Receipts", "الإيصالات العامة"),
            "openingbalances" => T("Opening Balances", "الرصيد الافتتاحي"),
            "reportingdimensions" => T("Reporting Dimensions", "أبعاد التقارير"),
            "cashboxes" => T("Cash Boxes", "الصناديق النقدية"),
            "bankaccounts" => T("Bank Accounts", "الحسابات البنكية"),
            "expenses" => T("Expenses", "المصروفات"),
            "employees" => T("Employees", "الموظفين"),
            "employeedocuments" => T("Employee Documents", "المستندات المرتبطة بالموظفين"),
            "payrollentries" => T("Payroll", "قيود الرواتب"),
            "employeedeductions" => T("Deductions", "الخصومات"),
            "employeebonuses" => T("Bonuses", "المكافآت"),
            "employeeloans" => T("Loans", "القروض"),
            "employeereceipts" => T("Receipts", "الإيصالات"),
            "employeerequests" => T("Requests", "إدارة الطلبات"),
            "reports" => T("Reports Center", "مركز التقارير"),
            "settings" => T("Settings", "الإعدادات"),
            _ => section
        };

        return (section, page);
    }

    var (sectionLabel, pageLabel) = Crumbs();
    var pageTitle = pageLabel;

    var loginName = User?.Identity?.Name ?? "";
    var initials = string.IsNullOrWhiteSpace(loginName)
        ? "B"
        : loginName.Trim().Substring(0, 1).ToUpperInvariant();
    var profileRole = User != null && SignInManager.IsSignedIn(User)
        ? T("Account Owner", "مالك الحساب")
        : T("Guest session", "جلسة زائر");

    // Server-side pre-paint of the sidebar state to eliminate flicker on navigation.
    var sidebarCookie = Context.Request.Cookies["bestgen_sidebar"];
    var sidebarCollapsed = string.Equals(sidebarCookie, "1", StringComparison.Ordinal);
    var shellClass = sidebarCollapsed ? "app-shell sidebar-collapsed" : "app-shell";

    // Bootstrap icon for each child controller, rendered inside sub-links so they have
    // a glyph to show in rail mode.
    string SubIcon(string c) => c.ToLowerInvariant() switch
    {
        "customers" => "bi-person",
        "salesquotations" => "bi-file-text",
        "salesinvoices" => "bi-receipt",
        "salesreceipts" => "bi-cash-coin",
        "salesrefundreceipts" => "bi-arrow-counterclockwise",
        "creditnotes" => "bi-journal-arrow-up",
        "deliverynotes" => "bi-truck",
        "salespricepolicies" => "bi-tag",
        "suppliers" => "bi-building",
        "purchaseorders" => "bi-clipboard-check",
        "purchaseinvoices" => "bi-receipt-cutoff",
        "supplierpayments" => "bi-credit-card",
        "purchaserefundreceipts" => "bi-arrow-clockwise",
        "debitnotes" => "bi-journal-arrow-down",
        "goodsreceipts" => "bi-box-arrow-in-down",
        "purchasepricepolicies" => "bi-tags",
        "productcategories" => "bi-bookmark",
        "products" => "bi-box",
        "warehouses" => "bi-house-gear",
        "inventorycounts" => "bi-clipboard-data",
        "stocktransfers" => "bi-arrow-left-right",
        "fixedassets" => "bi-building",
        "assettags" => "bi-bookmark-star",
        "assetrentals" => "bi-clock-history",
        "accounts" => "bi-list-columns",
        "journalentries" => "bi-journal-text",
        "generalreceipts" => "bi-receipt",
        "openingbalances" => "bi-bank",
        "reportingdimensions" => "bi-bezier",
        "cashboxes" => "bi-cash-stack",
        "bankaccounts" => "bi-bank2",
        "expenses" => "bi-arrow-down-right-circle",
        "employees" => "bi-person-badge",
        "employeedocuments" => "bi-file-earmark",
        "payrollentries" => "bi-cash",
        "employeedeductions" => "bi-dash-circle",
        "employeebonuses" => "bi-plus-circle",
        "employeeloans" => "bi-piggy-bank",
        "employeereceipts" => "bi-receipt",
        "employeerequests" => "bi-envelope",
        _ => "bi-dot"
    };
}
<!DOCTYPE html>
<html lang="@lang" dir="@dir" data-culture="@culture">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle · Bestgen</title>
    <link rel="preconnect" href="https://cdn.jsdelivr.net" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/earlyaccess/droidarabickufi.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <script>
        // Apply persisted theme before paint so there's no flash.
        (function () {
            try {
                var t = localStorage.getItem('bestgen-app-theme');
                if (t === 'navy') document.documentElement.setAttribute('data-theme', 'navy');
            } catch (e) { /* ignore */ }
        })();
    </script>
    <link href="@bootstrapHref" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="icon" type="image/png" href="~/img/logo.png" />
    <link rel="apple-touch-icon" href="~/img/logo.png" />
    <link rel="manifest" href="~/manifest.webmanifest" />
    <meta name="theme-color" content="#1B2E4B" />
    <meta name="application-name" content="Bestgen" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Bestgen" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="@shellClass">
        <aside class="app-sidebar" id="appSidebar">
            <div class="brand">
                <a asp-controller="Dashboard" asp-action="Index" class="brand-card" title="Bestgen ERP">
                    <div class="brand-mark"><img src="~/img/logo-transparent.png" alt="Bestgen" /></div>
                    <div class="brand-meta">
                        <div class="brand-label">@T("Workspace", "مساحة العمل")</div>
                        <div class="brand-title">Bestgen ERP</div>
                    </div>
                </a>
            </div>

            <nav class="sidebar-nav">
                <a asp-controller="Dashboard" asp-action="Index" class="nav-link nav-item @(IsActive("Dashboard") ? "active" : "")" title="@T("Dashboard", "لوحة التحكم")">
                    <i class="bi bi-grid-1x2"></i><span>@T("Dashboard", "لوحة التحكم")</span>
                </a>

                @{ var salesActive = new[] { "Customers", "SalesQuotations", "SalesInvoices", "SalesReceipts", "SalesRefundReceipts", "CreditNotes", "DeliveryNotes", "SalesPricePolicies" }; }
                <details class="@GroupClass(salesActive)" @(IsActive(salesActive) ? "open" : "")>
                    <summary title="@T("Sales", "المبيعات")"><i class="bi bi-cart-check"></i><span>@T("Sales", "المبيعات")</span><i class="bi bi-chevron-down chev"></i></summary>
                    <div class="@CollapseClass(salesActive)">
                        <a asp-controller="Customers" asp-action="Index" class="nav-sublink @(IsActive("Customers") ? "active" : "")" title="@T("Customers", "قائمة العملاء")"><i class="bi @SubIcon("Customers")"></i><span>@T("Customers", "قائمة العملاء")</span></a>
                        <a asp-controller="SalesQuotations" asp-action="Index" class="nav-sublink @(IsActive("SalesQuotations") ? "active" : "")" title="@T("Quotations", "عروض الأسعار")"><i class="bi @SubIcon("SalesQuotations")"></i><span>@T("Quotations", "عروض الأسعار")</span></a>
                        <a asp-controller="SalesInvoices" asp-action="Index" class="nav-sublink @(IsActive("SalesInvoices") ? "active" : "")" title="@T("Sales Invoices", "فواتير المبيعات")"><i class="bi @SubIcon("SalesInvoices")"></i><span>@T("Sales Invoices", "فواتير المبيعات")</span></a>
                        <a asp-controller="SalesReceipts" asp-action="Index" class="nav-sublink @(IsActive("SalesReceipts") ? "active" : "")" title="@T("Sales Receipts", "إيصالات المبيعات")"><i class="bi @SubIcon("SalesReceipts")"></i><span>@T("Sales Receipts", "إيصالات المبيعات")</span></a>
                        <a asp-controller="SalesRefundReceipts" asp-action="Index" class="nav-sublink @(IsActive("SalesRefundReceipts") ? "active" : "")" title="@T("Refund Receipts", "إيصالات الاسترداد")"><i class="bi @SubIcon("SalesRefundReceipts")"></i><span>@T("Refund Receipts", "إيصالات الاسترداد")</span></a>
                        <a asp-controller="CreditNotes" asp-action="Index" class="nav-sublink @(IsActive("CreditNotes") ? "active" : "")" title="@T("Credit Notes", "الإشعارات الدائنة")"><i class="bi @SubIcon("CreditNotes")"></i><span>@T("Credit Notes", "الإشعارات الدائنة")</span></a>
                        <a asp-controller="DeliveryNotes" asp-action="Index" class="nav-sublink @(IsActive("DeliveryNotes") ? "active" : "")" title="@T("Delivery Notes", "سندات تسليم المبيعات")"><i class="bi @SubIcon("DeliveryNotes")"></i><span>@T("Delivery Notes", "سندات تسليم المبيعات")</span></a>
                        <a asp-controller="SalesPricePolicies" asp-action="Index" class="nav-sublink @(IsActive("SalesPricePolicies") ? "active" : "")" title="@T("Sales Pricing", "سياسات تسعير المبيعات")"><i class="bi @SubIcon("SalesPricePolicies")"></i><span>@T("Sales Pricing", "سياسات تسعير المبيعات")</span></a>
                    </div>
                </details>

                @{ var purchaseActive = new[] { "Suppliers", "PurchaseOrders", "PurchaseInvoices", "SupplierPayments", "PurchaseRefundReceipts", "DebitNotes", "GoodsReceipts", "PurchasePricePolicies" }; }
                <details class="@GroupClass(purchaseActive)" @(IsActive(purchaseActive) ? "open" : "")>
                    <summary title="@T("Purchases", "المشتريات")"><i class="bi bi-bag-check"></i><span>@T("Purchases", "المشتريات")</span><i class="bi bi-chevron-down chev"></i></summary>
                    <div class="@CollapseClass(purchaseActive)">
                        <a asp-controller="Suppliers" asp-action="Index" class="nav-sublink @(IsActive("Suppliers") ? "active" : "")" title="@T("Suppliers", "قائمة الموردين")"><i class="bi @SubIcon("Suppliers")"></i><span>@T("Suppliers", "قائمة الموردين")</span></a>
                        <a asp-controller="PurchaseOrders" asp-action="Index" class="nav-sublink @(IsActive("PurchaseOrders") ? "active" : "")" title="@T("Purchase Orders", "طلبات الشراء")"><i class="bi @SubIcon("PurchaseOrders")"></i><span>@T("Purchase Orders", "طلبات الشراء")</span></a>
                        <a asp-controller="PurchaseInvoices" asp-action="Index" class="nav-sublink @(IsActive("PurchaseInvoices") ? "active" : "")" title="@T("Purchase Invoices", "فواتير المشتريات")"><i class="bi @SubIcon("PurchaseInvoices")"></i><span>@T("Purchase Invoices", "فواتير المشتريات")</span></a>
                        <a asp-controller="SupplierPayments" asp-action="Index" class="nav-sublink @(IsActive("SupplierPayments") ? "active" : "")" title="@T("Supplier Payments", "إيصالات المشتريات")"><i class="bi @SubIcon("SupplierPayments")"></i><span>@T("Supplier Payments", "إيصالات المشتريات")</span></a>
                        <a asp-controller="PurchaseRefundReceipts" asp-action="Index" class="nav-sublink @(IsActive("PurchaseRefundReceipts") ? "active" : "")" title="@T("Purchase Refunds", "إيصالات الاسترداد")"><i class="bi @SubIcon("PurchaseRefundReceipts")"></i><span>@T("Purchase Refunds", "إيصالات الاسترداد")</span></a>
                        <a asp-controller="DebitNotes" asp-action="Index" class="nav-sublink @(IsActive("DebitNotes") ? "active" : "")" title="@T("Debit Notes", "الإشعارات المدينة")"><i class="bi @SubIcon("DebitNotes")"></i><span>@T("Debit Notes", "الإشعارات المدينة")</span></a>
                        <a asp-controller="GoodsReceipts" asp-action="Index" class="nav-sublink @(IsActive("GoodsReceipts") ? "active" : "")" title="@T("Goods Receipts", "سندات استلام المنتجات")"><i class="bi @SubIcon("GoodsReceipts")"></i><span>@T("Goods Receipts", "سندات استلام المنتجات")</span></a>
                        <a asp-controller="PurchasePricePolicies" asp-action="Index" class="nav-sublink @(IsActive("PurchasePricePolicies") ? "active" : "")" title="@T("Purchase Pricing", "سياسة تسعير الشراء")"><i class="bi @SubIcon("PurchasePricePolicies")"></i><span>@T("Purchase Pricing", "سياسة تسعير الشراء")</span></a>
                    </div>
                </details>

                @{ var inventoryActive = new[] { "ProductCategories", "Products", "Warehouses", "InventoryCounts", "StockTransfers" }; }
                <details class="@GroupClass(inventoryActive)" @(IsActive(inventoryActive) ? "open" : "")>
                    <summary title="@T("Products & Inventory", "المنتجات والمخزون")"><i class="bi bi-box-seam"></i><span>@T("Products & Inventory", "المنتجات والمخزون")</span><i class="bi bi-chevron-down chev"></i></summary>
                    <div class="@CollapseClass(inventoryActive)">
                        <a asp-controller="ProductCategories" asp-action="Index" class="nav-sublink @(IsActive("ProductCategories") ? "active" : "")" title="@T("Product Categories", "أصناف المنتجات")"><i class="bi @SubIcon("ProductCategories")"></i><span>@T("Product Categories", "أصناف المنتجات")</span></a>
                        <a asp-controller="Products" asp-action="Index" class="nav-sublink @(IsActive("Products") ? "active" : "")" title="@T("Products", "قائمة المنتجات")"><i class="bi @SubIcon("Products")"></i><span>@T("Products", "قائمة المنتجات")</span></a>
                        <a asp-controller="Warehouses" asp-action="Index" class="nav-sublink @(IsActive("Warehouses") ? "active" : "")" title="@T("Warehouses", "المخازن")"><i class="bi @SubIcon("Warehouses")"></i><span>@T("Warehouses", "المخازن")</span></a>
                        <a asp-controller="InventoryCounts" asp-action="Index" class="nav-sublink @(IsActive("InventoryCounts") ? "active" : "")" title="@T("Inventory Counts", "عمليات الجرد")"><i class="bi @SubIcon("InventoryCounts")"></i><span>@T("Inventory Counts", "عمليات الجرد")</span></a>
                        <a asp-controller="StockTransfers" asp-action="Index" class="nav-sublink @(IsActive("StockTransfers") ? "active" : "")" title="@T("Stock Transfers", "نقل المخزون")"><i class="bi @SubIcon("StockTransfers")"></i><span>@T("Stock Transfers", "نقل المخزون")</span></a>
                    </div>
                </details>

                @{ var assetsActive = new[] { "FixedAssets", "AssetTags", "AssetRentals" }; }
                <details class="@GroupClass(assetsActive)" @(IsActive(assetsActive) ? "open" : "")>
                    <summary title="@T("Fixed Assets", "الأصول الثابتة")"><i class="bi bi-buildings"></i><span>@T("Fixed Assets", "الأصول الثابتة")</span><i class="bi bi-chevron-down chev"></i></summary>
                    <div class="@CollapseClass(assetsActive)">
                        <a asp-controller="FixedAssets" asp-action="Index" class="nav-sublink @(IsActive("FixedAssets") ? "active" : "")" title="@T("Assets", "أصول")"><i class="bi @SubIcon("FixedAssets")"></i><span>@T("Assets", "أصول")</span></a>
                        <a asp-controller="AssetTags" asp-action="Index" class="nav-sublink @(IsActive("AssetTags") ? "active" : "")" title="@T("Asset Tags", "وسوم الأصول")"><i class="bi @SubIcon("AssetTags")"></i><span>@T("Asset Tags", "وسوم الأصول")</span></a>
                        <a asp-controller="AssetRentals" asp-action="Index" class="nav-sublink @(IsActive("AssetRentals") ? "active" : "")" title="@T("Asset Rentals", "تأجيرات الأصول")"><i class="bi @SubIcon("AssetRentals")"></i><span>@T("Asset Rentals", "تأجيرات الأصول")</span></a>
                    </div>
                </details>

                @{ var accountingActive = new[] { "Accounts", "JournalEntries", "GeneralReceipts", "OpeningBalances", "ReportingDimensions", "CashBoxes", "BankAccounts", "Expenses", "TaxRates" }; }
                <details class="@GroupClass(accountingActive)" @(IsActive(accountingActive) ? "open" : "")>
                    <summary title="@T("Advanced Accounting", "المحاسبة المتقدمة")"><i class="bi bi-diagram-3"></i><span>@T("Advanced Accounting", "المحاسبة المتقدمة")</span><i class="bi bi-chevron-down chev"></i></summary>
                    <div class="@CollapseClass(accountingActive)">
                        <a asp-controller="Accounts" asp-action="Index" class="nav-sublink @(IsActive("Accounts") ? "active" : "")" title="@T("Chart of Accounts", "شجرة الحسابات")"><i class="bi @SubIcon("Accounts")"></i><span>@T("Chart of Accounts", "شجرة الحسابات")</span></a>
                        <a asp-controller="JournalEntries" asp-action="Index" class="nav-sublink @(IsActive("JournalEntries") ? "active" : "")" title="@T("Journal Entries", "القيود اليدوية")"><i class="bi @SubIcon("JournalEntries")"></i><span>@T("Journal Entries", "القيود اليدوية")</span></a>
                        <a asp-controller="GeneralReceipts" asp-action="Index" class="nav-sublink @(IsActive("GeneralReceipts") ? "active" : "")" title="@T("General Receipts", "الإيصالات العامة")"><i class="bi @SubIcon("GeneralReceipts")"></i><span>@T("General Receipts", "الإيصالات العامة")</span></a>

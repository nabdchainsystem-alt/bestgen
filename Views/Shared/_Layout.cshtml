    <!-- Web Push: subscribe / unsubscribe via the bell button -->
    <script>
    (function () {
        if (!('serviceWorker' in navigator) || !('PushManager' in window) || !('Notification' in window)) return;
        const bell = document.getElementById('pushBell');
        if (!bell) return;

        function urlBase64ToUint8Array(b64) {
            const padding = '='.repeat((4 - b64.length % 4) % 4);
            const base64 = (b64 + padding).replace(/-/g, '+').replace(/_/g, '/');
            const raw = atob(base64);
            const out = new Uint8Array(raw.length);
            for (let i = 0; i < raw.length; ++i) out[i] = raw.charCodeAt(i);
            return out;
        }

        async function getReg() {
            if (navigator.serviceWorker.controller) return navigator.serviceWorker.ready;
            return navigator.serviceWorker.register('/sw.js').then(() => navigator.serviceWorker.ready);
        }

        async function refresh() {
            const reg = await getReg();
            const sub = await reg.pushManager.getSubscription();
            const granted = Notification.permission === 'granted';
            bell.style.display = 'inline-flex';
            bell.classList.toggle('active', granted && !!sub);
            bell.title = granted && sub
                ? @Html.Raw($"\"{T("Notifications on (click to disable)", "الإشعارات مفعّلة (اضغط للتعطيل)")}\"")
                : @Html.Raw($"\"{T("Enable notifications", "تفعيل الإشعارات")}\"");
            const icon = bell.querySelector('i');
            if (icon) icon.className = granted && sub ? 'bi bi-bell-fill' : 'bi bi-bell';
        }

        async function subscribe() {
            try {
                const r = await fetch('/Push/PublicKey');
                const j = await r.json();
                if (!j.configured || !j.publicKey) {
                    alert('@T("Push is not configured. Ask an admin to generate VAPID keys.", "إشعارات الدفع غير مكوّنة. اطلب من المدير إنشاء مفاتيح VAPID.")');
                    return;
                }
                const perm = await Notification.requestPermission();
                if (perm !== 'granted') return;
                const reg = await getReg();
                const sub = await reg.pushManager.subscribe({
                    userVisibleOnly: true,
                    applicationServerKey: urlBase64ToUint8Array(j.publicKey)
                });
                await fetch('/Push/Subscribe', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        endpoint: sub.endpoint,
                        p256dh: btoa(String.fromCharCode(...new Uint8Array(sub.getKey('p256dh')))),
                        auth:   btoa(String.fromCharCode(...new Uint8Array(sub.getKey('auth'))))
                    })
                });
            } catch (e) { console.warn('push subscribe failed', e); }
            await refresh();
        }

        async function unsubscribe() {
            const reg = await getReg();
            const sub = await reg.pushManager.getSubscription();
            if (sub) {
                await fetch('/Push/Unsubscribe', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ endpoint: sub.endpoint })
                });
                await sub.unsubscribe();
            }
            await refresh();
        }

        bell.addEventListener('click', async () => {
            const reg = await getReg();
            const sub = await reg.pushManager.getSubscription();
            if (sub && Notification.permission === 'granted') await unsubscribe();
            else await subscribe();
        });

        refresh();
    })();
    </script>

    <!-- PWA: register service worker + show install button when supported -->
    <button id="bestgenInstallBtn" type="button"
            style="display:none;position:fixed;bottom:18px;@(isArabic ? "left" : "right"):18px;z-index:1080;
                   border:0;border-radius:999px;padding:10px 18px;font-weight:600;cursor:pointer;
                   background:var(--navy,#1B2E4B);color:#fff;box-shadow:0 6px 20px rgba(27,46,75,.25);">
        <i class="bi bi-download"></i> @T("Install Bestgen", "تثبيت بستجين")
    </button>
    <script>
        (function () {
            // Register service worker (production-only — reload-loop friendly in dev).
            if ('serviceWorker' in navigator && location.protocol === 'https:' || location.hostname === 'localhost') {
                window.addEventListener('load', function () {
                    navigator.serviceWorker.register('/sw.js').catch(function () { /* swallow */ });
                });
            }

            // Install prompt UX.
            var deferred = null;
            var btn = document.getElementById('bestgenInstallBtn');
            window.addEventListener('beforeinstallprompt', function (e) {
                e.preventDefault();
                deferred = e;
                if (btn) btn.style.display = 'inline-flex';
            });
            if (btn) {
                btn.addEventListener('click', async function () {
                    if (!deferred) return;
                    btn.style.display = 'none';
                    deferred.prompt();
                    try { await deferred.userChoice; } catch (e) { /* ignore */ }
                    deferred = null;
                });
            }
            window.addEventListener('appinstalled', function () {
                if (btn) btn.style.display = 'none';
            });
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)

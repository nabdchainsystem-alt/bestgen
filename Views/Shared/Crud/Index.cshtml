@using System.Globalization
@model IReadOnlyList<object>
@{
    var isArabic = CultureInfo.CurrentUICulture.Name.StartsWith("ar", StringComparison.OrdinalIgnoreCase);
    string T(string en, string ar) => isArabic ? ar : en;

    var controllerName = (string)ViewBag.ControllerName;
    var title = (string)ViewBag.EntityTitle;
    var description = (string)ViewBag.EntityDescription;
    var entityType = ViewBag.EntityType as Type ?? Model.FirstOrDefault()?.GetType();
    var properties = entityType is null ? new List<System.Reflection.PropertyInfo>() : EntityDisplayHelper.GetListProperties(entityType).ToList();
    ViewData["Title"] = title;
    var createText = T($"Add {title}", $"إضافة {title}");
}

<partial name="_PageHeader" model="@(new PageHeaderViewModel(title, description, "Create", controllerName, createText))" />

<section class="data-panel">
    <partial name="_SearchBar" />

    @if (!Model.Any() || entityType is null)
    {
        <partial name="_EmptyState" model="@(T($"Start by adding your first {title} record.", $"ابدأ بإضافة أول سجل في {title}."))" />
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        @foreach (var property in properties)
                        {
                            <th>@EntityDisplayHelper.Label(property.Name)</th>
                        }
                        <th class="text-nowrap">@T("Actions", "الإجراءات")</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model)
                    {
                        var id = (int)(entityType.GetProperty("Id")?.GetValue(row) ?? 0);
                        <tr>
                            @foreach (var property in properties)
                            {
                                var value = property.GetValue(row);
                                <td>
                                    @if (EntityDisplayHelper.IsStatusProperty(property.Name))
                                    {
                                        <partial name="_StatusBadge" model="@(new StatusBadgeViewModel(value))" />
                                    }
                                    else
                                    {
                                        @EntityDisplayHelper.FormatValue(value, property.Name)
                                    }
                                </td>
                            }
                            <td><partial name="_ActionButtons" model="@id" /></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        var page = (int)(ViewBag.Page ?? 1);
        var totalPages = (int)(ViewBag.TotalPages ?? 1);
        var totalRows = (int)(ViewBag.TotalRows ?? Model.Count);
        var pageSize = (int)(ViewBag.PageSize ?? Model.Count);
        var firstRow = totalRows == 0 ? 0 : ((page - 1) * pageSize) + 1;
        var lastRow = Math.Min(page * pageSize, totalRows);
        var currentSearch = (string?)ViewBag.CurrentSearch;
        var currentStatus = (string?)ViewBag.CurrentStatus;
        <div class="d-flex justify-content-between align-items-center text-muted small pt-2 flex-wrap gap-2">
            <span>@T($"Showing {firstRow}–{lastRow} of {totalRows}", $"عرض {firstRow}–{lastRow} من {totalRows}")</span>
            @if (totalPages > 1)
            {
                <nav class="pagination-nav">
                    <a class="btn btn-sm btn-outline-secondary @(page <= 1 ? "disabled" : "")"
                       asp-controller="@controllerName" asp-action="Index"
                       asp-route-page="@(page - 1)" asp-route-q="@currentSearch" asp-route-status="@currentStatus">
                        <i class="bi bi-chevron-@(isArabic ? "right" : "left")"></i> @T("Previous", "السابق")
                    </a>
                    <span class="px-2">@T($"Page {page} of {totalPages}", $"صفحة {page} من {totalPages}")</span>
                    <a class="btn btn-sm btn-outline-secondary @(page >= totalPages ? "disabled" : "")"
                       asp-controller="@controllerName" asp-action="Index"
                       asp-route-page="@(page + 1)" asp-route-q="@currentSearch" asp-route-status="@currentStatus">
                        @T("Next", "التالي") <i class="bi bi-chevron-@(isArabic ? "left" : "right")"></i>
                    </a>
                </nav>
            }
        </div>
    }
</section>

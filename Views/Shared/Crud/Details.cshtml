@using System.Globalization
@model object
@{
    var isArabic = CultureInfo.CurrentUICulture.Name.StartsWith("ar", StringComparison.OrdinalIgnoreCase);
    string T(string en, string ar) => isArabic ? ar : en;

    var controllerName = (string)ViewBag.ControllerName;
    var title = (string)ViewBag.EntityTitle;
    var entityType = Model.GetType();
    var id = (int)(entityType.GetProperty("Id")?.GetValue(Model) ?? 0);
    var properties = EntityDisplayHelper.GetFormProperties(entityType).ToList();
    var statusProperty = entityType.GetProperty("Status") ?? entityType.GetProperty("IsActive");
    var statusValue = statusProperty?.GetValue(Model);
    ViewData["Title"] = T($"{title} details", $"تفاصيل {title}");
}

<div class="page-header">
    <div>
        <h1>@T($"{title} details", $"تفاصيل {title}")</h1>
        <p>@T("View the record and its related data.", "عرض بيانات السجل والبيانات المرتبطة به.")</p>
    </div>
    <div class="d-flex gap-2">
        @if (statusProperty is not null)
        {
            <partial name="_StatusBadge" model="@(new StatusBadgeViewModel(statusValue))" />
        }
        <a asp-controller="@controllerName" asp-action="Edit" asp-route-id="@id" class="btn btn-primary"><i class="bi bi-pencil"></i> @T("Edit", "تعديل")</a>
        <a asp-controller="@controllerName" asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-@(isArabic ? "right" : "left")"></i> @T("Back to list", "العودة إلى القائمة")</a>
    </div>
</div>

<section class="details-panel">
    <div class="summary-grid">
        @foreach (var property in properties.Where(property => EntityDisplayHelper.IsMoneyProperty(property.Name)).Take(4))
        {
            <div class="summary-card">
                <span>@EntityDisplayHelper.Label(property.Name)</span>
                <strong>@EntityDisplayHelper.FormatValue(property.GetValue(Model), property.Name)</strong>
            </div>
        }
    </div>

    <div class="table-responsive">
        <table class="table">
            <tbody>
                @foreach (var property in properties)
                {
                    var value = property.GetValue(Model);
                    <tr>
                        <th style="width: 260px">@EntityDisplayHelper.Label(property.Name)</th>
                        <td>
                            @if (EntityDisplayHelper.IsStatusProperty(property.Name))
                            {
                                <partial name="_StatusBadge" model="@(new StatusBadgeViewModel(value))" />
                            }
                            else
                            {
                                @EntityDisplayHelper.FormatValue(value, property.Name)
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @{
        var auditEntries = ViewBag.AuditEntries as List<bestgen.Models.AuditEntry> ?? new List<bestgen.Models.AuditEntry>();
        string ActionLabel(bestgen.Models.AuditAction a) => a switch
        {
            bestgen.Models.AuditAction.Create => T("Created", "إنشاء"),
            bestgen.Models.AuditAction.Update => T("Updated", "تعديل"),
            bestgen.Models.AuditAction.Delete => T("Deleted", "حذف"),
            _ => a.ToString()
        };
        string ActionBadge(bestgen.Models.AuditAction a) => a switch
        {
            bestgen.Models.AuditAction.Create => "bg-emerald-soft text-emerald",
            bestgen.Models.AuditAction.Update => "bg-blue-soft text-blue",
            bestgen.Models.AuditAction.Delete => "bg-danger-soft text-danger",
            _ => "bg-secondary-subtle text-secondary"
        };
    }
    <ul class="nav nav-tabs mt-4" role="tablist">
        <li class="nav-item" role="presentation"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#audit" type="button">@T("Activity log", "سجل النشاط") <span class="badge bg-secondary-subtle text-secondary ms-1">@auditEntries.Count</span></button></li>
    </ul>
    <div class="tab-content pt-3">
        <div class="tab-pane fade show active" id="audit">
            @if (auditEntries.Count == 0)
            {
                <p class="text-muted">@T("No activity recorded yet for this record.", "لا يوجد نشاط مسجل لهذا السجل بعد.")</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th>@T("When", "التاريخ")</th>
                                <th>@T("Action", "الإجراء")</th>
                                <th>@T("User", "المستخدم")</th>
                                <th>@T("Changed fields", "الحقول المعدلة")</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var audit in auditEntries)
                            {
                                <tr>
                                    <td class="text-nowrap">@audit.At.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                    <td><span class="badge @ActionBadge(audit.Action)">@ActionLabel(audit.Action)</span></td>
                                    <td>@(audit.UserName ?? "-")</td>
                                    <td class="text-muted">@(audit.Summary ?? "-")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</section>

@using System.Globalization
@model UserFormViewModel
@{
    var isArabic = CultureInfo.CurrentUICulture.Name.StartsWith("ar", StringComparison.OrdinalIgnoreCase);
    string T(string en, string ar) => isArabic ? ar : en;
    ViewData["Title"] = T("Add user", "إضافة مستخدم");
    var roles = ViewBag.AllRoles as IList<string> ?? new List<string>();
}

<partial name="_PageHeader" model="@(new PageHeaderViewModel(
    T("Add user", "إضافة مستخدم"),
    T("Create a new user and assign roles.", "إنشاء مستخدم جديد وإسناد أدوار له.")))" />

<section class="form-panel">
    <form asp-action="CreateUser" method="post">
        <div asp-validation-summary="All" class="text-danger mb-3"></div>
        <div class="form-grid">
            <div>
                <label asp-for="Email" class="form-label">@T("Email", "البريد الإلكتروني")</label>
                <input asp-for="Email" class="form-control" type="email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="FullName" class="form-label">@T("Full name", "الاسم الكامل")</label>
                <input asp-for="FullName" class="form-control" />
            </div>
            <div>
                <label asp-for="Password" class="form-label">@T("Password", "كلمة المرور")</label>
                <input asp-for="Password" class="form-control" type="password" autocomplete="new-password" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            <div class="full-width">
                <label class="form-label">@T("Roles", "الأدوار")</label>
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var role in roles)
                    {
                        <label class="form-check">
                            <input class="form-check-input" type="checkbox" name="Roles" value="@role" @(Model.Roles.Contains(role) ? "checked" : "") />
                            <span class="form-check-label">@role</span>
                        </label>
                    }
                </div>
            </div>
        </div>
        <div class="d-flex gap-2 mt-4">
            <button class="btn btn-primary" type="submit"><i class="bi bi-check2"></i> @T("Create", "إنشاء")</button>
            <a asp-action="UsersRoles" class="btn btn-outline-secondary">@T("Cancel", "إلغاء")</a>
        </div>
    </form>
</section>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }

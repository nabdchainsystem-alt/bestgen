@using System.Globalization
@model CompanySettings
@{
    var isArabic = CultureInfo.CurrentUICulture.Name.StartsWith("ar", StringComparison.OrdinalIgnoreCase);
    string T(string en, string ar) => isArabic ? ar : en;
    ViewData["Title"] = T("Edit company settings", "تعديل إعدادات الشركة");
}

<partial name="_PageHeader" model="@(new PageHeaderViewModel(
    T("Edit company settings", "تعديل إعدادات الشركة"),
    T("Update your organization details and core invoicing settings.", "حدّث بيانات المنشأة وإعدادات الفواتير الأساسية.")))" />

<section class="form-panel">
    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        <input asp-for="Id" type="hidden" />
        <div asp-validation-summary="All" class="form-validation-summary"></div>
        <div class="form-grid">
            <div>
                <label asp-for="CompanyNameAr" class="form-label">@T("Arabic company name", "اسم الشركة عربي")</label>
                <input asp-for="CompanyNameAr" class="form-control" />
                <span asp-validation-for="CompanyNameAr" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="CompanyNameEn" class="form-label">@T("English company name", "اسم الشركة إنجليزي")</label>
                <input asp-for="CompanyNameEn" class="form-control" />
            </div>
            <div>
                <label asp-for="VatNumber" class="form-label">@T("VAT number", "الرقم الضريبي")</label>
                <input asp-for="VatNumber" class="form-control" />
            </div>
            <div>
                <label asp-for="CommercialRegistrationNumber" class="form-label">@T("Commercial registration", "السجل التجاري")</label>
                <input asp-for="CommercialRegistrationNumber" class="form-control" />
            </div>
            <div class="full-width">
                <label asp-for="Address" class="form-label">@T("Address", "العنوان")</label>
                <textarea asp-for="Address" class="form-control" rows="2"></textarea>
            </div>
            <div>
                <label asp-for="City" class="form-label">@T("City", "المدينة")</label>
                <input asp-for="City" class="form-control" />
            </div>
            <div>
                <label asp-for="Country" class="form-label">@T("Country", "الدولة")</label>
                <input asp-for="Country" class="form-control" />
            </div>
            <div>
                <label asp-for="DefaultVatRate" class="form-label">@T("Default VAT rate", "نسبة الضريبة الافتراضية")</label>
                <input asp-for="DefaultVatRate" class="form-control" type="number" step="0.01" />
            </div>
            <div>
                <label asp-for="InvoicePrefix" class="form-label">@T("Sales invoice prefix", "بادئة فواتير البيع")</label>
                <input asp-for="InvoicePrefix" class="form-control" />
            </div>
            <div>
                <label asp-for="PurchaseInvoicePrefix" class="form-label">@T("Purchase invoice prefix", "بادئة فواتير الشراء")</label>
                <input asp-for="PurchaseInvoicePrefix" class="form-control" />
            </div>
            <div>
                <label asp-for="LogoPath" class="form-label">@T("Logo path", "مسار الشعار")</label>
                <input asp-for="LogoPath" class="form-control" readonly />
            </div>
            <div class="full-width">
                <label class="form-label">@T("Upload logo", "رفع شعار جديد")</label>
                <input type="file" name="logo" class="form-control" accept="image/*" />
                @if (!string.IsNullOrWhiteSpace(Model.LogoPath))
                {
                    <div class="mt-2"><img src="@Model.LogoPath" alt="logo" style="max-height:60px;border-radius:6px;" /></div>
                }
            </div>
        </div>
        <div class="d-flex gap-2 mt-4">
            <button class="btn btn-primary" type="submit"><i class="bi bi-check2"></i> @T("Save", "حفظ")</button>
            <a asp-action="Index" class="btn btn-outline-secondary">@T("Cancel", "إلغاء")</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@model CompanySettings
@{
    ViewData["Title"] = "تعديل إعدادات الشركة";
}

<partial name="_PageHeader" model="@(new PageHeaderViewModel("تعديل إعدادات الشركة", "حدّث بيانات المنشأة وإعدادات الفواتير الأساسية."))" />

<section class="form-panel">
    <form asp-action="Edit" method="post">
        <input asp-for="Id" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <div class="form-grid">
            <div>
                <label asp-for="CompanyNameAr" class="form-label">اسم الشركة عربي</label>
                <input asp-for="CompanyNameAr" class="form-control" />
                <span asp-validation-for="CompanyNameAr" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="CompanyNameEn" class="form-label">اسم الشركة إنجليزي</label>
                <input asp-for="CompanyNameEn" class="form-control" />
            </div>
            <div>
                <label asp-for="VatNumber" class="form-label">الرقم الضريبي</label>
                <input asp-for="VatNumber" class="form-control" />
            </div>
            <div>
                <label asp-for="CommercialRegistrationNumber" class="form-label">السجل التجاري</label>
                <input asp-for="CommercialRegistrationNumber" class="form-control" />
            </div>
            <div class="full-width">
                <label asp-for="Address" class="form-label">العنوان</label>
                <textarea asp-for="Address" class="form-control" rows="2"></textarea>
            </div>
            <div>
                <label asp-for="City" class="form-label">المدينة</label>
                <input asp-for="City" class="form-control" />
            </div>
            <div>
                <label asp-for="Country" class="form-label">الدولة</label>
                <input asp-for="Country" class="form-control" />
            </div>
            <div>
                <label asp-for="DefaultVatRate" class="form-label">نسبة الضريبة الافتراضية</label>
                <input asp-for="DefaultVatRate" class="form-control" type="number" step="0.01" />
            </div>
            <div>
                <label asp-for="InvoicePrefix" class="form-label">بادئة فواتير البيع</label>
                <input asp-for="InvoicePrefix" class="form-control" />
            </div>
            <div>
                <label asp-for="PurchaseInvoicePrefix" class="form-label">بادئة فواتير الشراء</label>
                <input asp-for="PurchaseInvoicePrefix" class="form-control" />
            </div>
            <div>
                <label asp-for="LogoPath" class="form-label">مسار الشعار</label>
                <input asp-for="LogoPath" class="form-control" placeholder="Placeholder" />
            </div>
        </div>
        <div class="d-flex gap-2 mt-4">
            <button class="btn btn-primary" type="submit"><i class="bi bi-check2"></i> حفظ</button>
            <a asp-action="Index" class="btn btn-outline-secondary">إلغاء</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

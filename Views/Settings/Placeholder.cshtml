@using bestgen.Controllers
@model PlaceholderViewModel
@{
    ViewData["Title"] = Model.Title;
}

<partial name="_PageHeader" model="@(new PageHeaderViewModel(Model.Title, Model.Description))" />

<section class="details-panel">
    <div class="panel-title">
        <h2>الحقول والإعدادات المخططة</h2>
        <span class="badge bg-blue-soft text-blue">قيد التجهيز</span>
    </div>
    <div class="form-grid">
        @foreach (var item in Model.Items)
        {
            <div>
                <label class="form-label">@item</label>
                <input class="form-control" placeholder="سيتم تفعيلها قريبا" disabled />
            </div>
        }
    </div>

    <div class="panel-title mt-4">
        <h2>خطة التطوير</h2>
        <span class="badge bg-secondary-subtle text-secondary">Roadmap</span>
    </div>
    <div class="roadmap-list">
        <span>تصميم النموذج</span>
        <span>تخزين الإعدادات</span>
        <span>الصلاحيات</span>
        <span>تطبيق على باقي الوحدات</span>
    </div>
</section>

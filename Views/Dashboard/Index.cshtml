@using System.Globalization
@using System.Text.Json
@model DashboardViewModel
@{
    var isArabic = CultureInfo.CurrentUICulture.Name.StartsWith("ar", StringComparison.OrdinalIgnoreCase);
    string T(string en, string ar) => isArabic ? ar : en;
    string pickName(string nameAr, string? nameEn) => isArabic ? nameAr : (string.IsNullOrWhiteSpace(nameEn) ? nameAr : nameEn!);
    string money(decimal value) => isArabic ? $"{value:N2} ر.س" : $"SAR {value:N2}";

    ViewData["Title"] = T("Dashboard", "لوحة التحكم");

    var monthlyLabels = Model.MonthlyComparison.Select(x => x.Month);
    var monthlySales = Model.MonthlyComparison.Select(x => x.Sales);
    var monthlyPurchases = Model.MonthlyComparison.Select(x => x.Purchases);
    var cashLabels = Model.CashFlow.Select(x => x.Month);
    var cashInflow = Model.CashFlow.Select(x => x.Inflow);
    var cashOutflow = Model.CashFlow.Select(x => x.Outflow);
    var expenseLabels = Model.ExpensesByCategory.Select(x => x.Category);
    var expenseValues = Model.ExpensesByCategory.Select(x => x.Total);
    var inventoryLabels = Model.InventoryByValue.Select(x => x.Label);
    var inventoryValues = Model.InventoryByValue.Select(x => x.Value);

    // Sparkline series (≤ 6 months) for the KPI cards
    var salesSpark = Model.MonthlyComparison.Select(x => x.Sales).ToList();
    var purchasesSpark = Model.MonthlyComparison.Select(x => x.Purchases).ToList();
    var profitSpark = Model.MonthlyComparison.Select(x => x.Sales - x.Purchases).ToList();
    var inflowSpark = Model.CashFlow.Select(x => x.Inflow).ToList();
    var outflowSpark = Model.CashFlow.Select(x => x.Outflow).ToList();

    decimal? Delta(IReadOnlyList<decimal> series)
    {
        if (series.Count < 2) return null;
        var last = series[^1];
        var prev = series[^2];
        if (prev == 0) return null;
        return Math.Round((last - prev) / Math.Abs(prev) * 100m, 1);
    }

    var salesDelta = Delta(salesSpark);
    var purchasesDelta = Delta(purchasesSpark);
    var profitDelta = Delta(profitSpark);
    var inflowDelta = Delta(inflowSpark);
    var outflowDelta = Delta(outflowSpark);
    var vsLastMonth = T("vs last month", "مقابل الشهر الماضي");
    var ytd = T("YTD", "منذ بداية السنة");
}

<partial name="_PageHeader" model="@(new PageHeaderViewModel(
    T("Dashboard", "لوحة التحكم"),
    T("A complete overview of sales, purchases, cash, inventory, and smart alerts.",
      "نظرة شاملة على المبيعات والمشتريات والنقد والمخزون والتنبيهات الذكية.")))" />

<section class="metrics-grid">
    <partial name="_DashboardCard" model="@(new DashboardCardViewModel(
        T("TOTAL SALES","إجمالي المبيعات"), money(Model.TotalSales), "bi-receipt", "indigo",
        T("YTD posted","منذ بداية السنة"), salesDelta, vsLastMonth, salesSpark))" />
    <partial name="_DashboardCard" model="@(new DashboardCardViewModel(
        T("TOTAL PURCHASES","إجمالي المشتريات"), money(Model.TotalPurchases), "bi-bag-check", "blue",
        T("YTD approved","فواتير الموردين"), purchasesDelta, vsLastMonth, purchasesSpark))" />
    <partial name="_DashboardCard" model="@(new DashboardCardViewModel(
        T("NET PROFIT","صافي الربح"), money(Model.NetProfit), "bi-graph-up-arrow", "emerald",
        T("Sales − Purchases − Expenses","مبيعات − مشتريات − مصروفات"), profitDelta, vsLastMonth, profitSpark))" />
    <partial name="_DashboardCard" model="@(new DashboardCardViewModel(
        T("CASH BALANCE","رصيد الخزينة"), money(Model.CashBalance), "bi-cash-coin", "warning",
        T("All cash boxes","إجمالي الصناديق النقدية"), null, null, inflowSpark))" />
    <partial name="_DashboardCard" model="@(new DashboardCardViewModel(
        T("BANK BALANCE","رصيد البنك"), money(Model.BankBalance), "bi-bank", "blue",
        T("All bank accounts","إجمالي الحسابات البنكية"), null, null, null))" />
    <partial name="_DashboardCard" model="@(new DashboardCardViewModel(
        T("RECEIVABLES","العملاء المدينون"), money(Model.Receivables), "bi-people", "warning",
        T("Open customer balances","ذمم مدينة مفتوحة"), null, null, null))" />
    <partial name="_DashboardCard" model="@(new DashboardCardViewModel(
        T("PAYABLES","الموردون الدائنون"), money(Model.Payables), "bi-person-lines-fill", "navy",
        T("Outstanding to suppliers","ذمم دائنة مستحقة"), null, null, outflowSpark))" />
    <partial name="_DashboardCard" model="@(new DashboardCardViewModel(
        T("INVENTORY VALUE","قيمة المخزون"), money(Model.InventoryValue), "bi-box-seam", "indigo",
        T("At purchase cost","بسعر تكلفة الشراء"), null, null, null))" />
    <partial name="_DashboardCard" model="@(new DashboardCardViewModel(
        T("LOW-STOCK ITEMS","منتجات منخفضة المخزون"), Model.LowStockCount.ToString(), "bi-exclamation-triangle", "danger",
        T("Reached reorder point","وصلت حد الطلب"), null, null, null))" />
    <partial name="_DashboardCard" model="@(new DashboardCardViewModel(
        T("OVERDUE INVOICES","فواتير متأخرة"), Model.OverdueInvoiceCount.ToString(), "bi-clock-history", "danger",
        T("> 30 days unpaid","أكثر من 30 يوما"), null, null, null))" />
</section>

<section class="dashboard-grid">
    <div class="chart-panel">
        <div class="panel-title"><h2>@T("Sales vs Purchases","المبيعات مقابل المشتريات")</h2><span class="badge bg-blue-soft text-blue">@T("Last 6 months","آخر 6 أشهر")</span></div>
        <div id="salesPurchasesChart" class="echart" style="height:320px;"></div>
    </div>
    <div class="alerts-panel">
        <div class="panel-title"><h2>@T("Smart Alerts","تنبيهات ذكية")</h2><span class="badge bg-emerald-soft text-emerald">@T("Live","حية")</span></div>
        <ul class="alerts-list">
            @foreach (var alert in Model.Alerts)
            {
                <li class="alert-item @alert.Tone">
                    <div class="alert-dot"><i class="bi @alert.Icon"></i></div>
                    <div>
                        <h4>@alert.Title</h4>
                        <p>@alert.Message</p>
                    </div>
                </li>
            }
        </ul>
    </div>
</section>

<section class="dashboard-grid">
    <div class="chart-panel">
        <div class="panel-title"><h2>@T("Cash Flow","التدفق النقدي")</h2><span class="badge bg-emerald-soft text-emerald">@T("In / Out","داخل / خارج")</span></div>
        <div id="cashFlowChart" class="echart" style="height:320px;"></div>
    </div>
    <div class="chart-panel">
        <div class="panel-title"><h2>@T("Expenses by Category","المصروفات حسب التصنيف")</h2><span class="badge bg-blue-soft text-blue">@T("Analysis","تحليل")</span></div>
        <div id="expensesChart" class="echart" style="height:320px;"></div>
    </div>
</section>

<section class="dashboard-grid">
    <div class="chart-panel">
        <div class="panel-title"><h2>@T("Inventory by Value","المخزون حسب القيمة")</h2><span class="badge bg-blue-soft text-blue">@Model.InventoryByValue.Count @T("categories","تصنيف")</span></div>
        <div id="inventoryChart" class="echart" style="height:340px;"></div>
    </div>
    <div class="table-panel">
        <div class="panel-title"><h2>@T("Low-Stock Products","المنتجات منخفضة المخزون")</h2><a asp-controller="Products" asp-action="Index">@T("Manage inventory","إدارة المخزون")</a></div>
        @if (!Model.LowStockProducts.Any())
        {
            <p class="text-muted mb-0">@T("No items below the reorder point right now.","لا توجد أصناف تحت حد الطلب حاليا.")</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm">
                    <thead><tr><th>@T("Item","الصنف")</th><th>SKU</th><th>@T("Current","الحالي")</th><th>@T("Min","الحد")</th></tr></thead>
                    <tbody>
                        @foreach (var product in Model.LowStockProducts)
                        {
                            <tr>
                                <td>@pickName(product.NameAr, product.NameEn)</td>
                                <td><span class="text-muted small">@product.SKU</span></td>
                                <td><span class="badge bg-danger-subtle text-danger">@product.CurrentStock</span></td>
                                <td>@product.MinimumStockLevel</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</section>

<section class="dashboard-grid">
    <div class="table-panel">
        <div class="panel-title"><h2>@T("Recent Sales Invoices","آخر فواتير المبيعات")</h2><a asp-controller="SalesInvoices" asp-action="Index">@T("View all","عرض الكل")</a></div>
        <div class="table-responsive">
            <table class="table table-sm">
                <thead><tr><th>@T("Invoice","الفاتورة")</th><th>@T("Customer","العميل")</th><th>@T("Total","الإجمالي")</th><th>@T("Status","الحالة")</th></tr></thead>
                <tbody>
                    @foreach (var invoice in Model.RecentSalesInvoices)
                    {
                        <tr>
                            <td><a asp-controller="SalesInvoices" asp-action="Details" asp-route-id="@invoice.Id">@invoice.InvoiceNumber</a></td>
                            <td>@(invoice.Customer == null ? "-" : pickName(invoice.Customer.NameAr, invoice.Customer.NameEn))</td>
                            <td>@money(invoice.GrandTotal)</td>
                            <td><partial name="_StatusBadge" model="@(new StatusBadgeViewModel(invoice.Status))" /></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="table-panel">
        <div class="panel-title"><h2>@T("Recent Purchase Invoices","آخر فواتير المشتريات")</h2><a asp-controller="PurchaseInvoices" asp-action="Index">@T("View all","عرض الكل")</a></div>
        <div class="table-responsive">
            <table class="table table-sm">
                <thead><tr><th>@T("Invoice","الفاتورة")</th><th>@T("Supplier","المورد")</th><th>@T("Total","الإجمالي")</th><th>@T("Status","الحالة")</th></tr></thead>
                <tbody>
                    @foreach (var invoice in Model.RecentPurchaseInvoices)
                    {
                        <tr>
                            <td><a asp-controller="PurchaseInvoices" asp-action="Details" asp-route-id="@invoice.Id">@invoice.PurchaseInvoiceNumber</a></td>
                            <td>@(invoice.Supplier == null ? "-" : pickName(invoice.Supplier.NameAr, invoice.Supplier.NameEn))</td>
                            <td>@money(invoice.GrandTotal)</td>
                            <td><partial name="_StatusBadge" model="@(new StatusBadgeViewModel(invoice.Status))" /></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>

<section class="dashboard-grid">
    <div class="table-panel">
        <div class="panel-title"><h2>@T("Top Debtor Customers","العملاء الأعلى مديونية")</h2><a asp-controller="Customers" asp-action="Index">@T("Customers","العملاء")</a></div>
        @if (!Model.TopDebtorCustomers.Any())
        {
            <p class="text-muted mb-0">@T("No customers carry an open balance.","لا يوجد عملاء عليهم رصيد مفتوح.")</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm">
                    <thead><tr><th>@T("Customer","العميل")</th><th>@T("City","المدينة")</th><th>@T("Outstanding","المتبقي")</th></tr></thead>
                    <tbody>
                        @foreach (var customer in Model.TopDebtorCustomers)
                        {
                            <tr>
                                <td>@pickName(customer.NameAr, customer.NameEn)</td>
                                <td>@(customer.City ?? "-")</td>
                                <td><span class="badge bg-warning-subtle text-warning-emphasis">@money(customer.CurrentBalance)</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
    <div class="table-panel">
        <div class="panel-title"><h2>@T("Top Creditor Suppliers","الموردون المستحق لهم")</h2><a asp-controller="Suppliers" asp-action="Index">@T("Suppliers","الموردون")</a></div>
        @if (!Model.TopCreditorSuppliers.Any())
        {
            <p class="text-muted mb-0">@T("No outstanding supplier balances right now.","لا توجد مستحقات للموردين حاليا.")</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm">
                    <thead><tr><th>@T("Supplier","المورد")</th><th>@T("City","المدينة")</th><th>@T("Owed","المستحق")</th></tr></thead>
                    <tbody>
                        @foreach (var supplier in Model.TopCreditorSuppliers)
                        {
                            <tr>
                                <td>@pickName(supplier.NameAr, supplier.NameEn)</td>
                                <td>@(supplier.City ?? "-")</td>
                                <td><span class="badge bg-blue-soft text-blue">@money(supplier.CurrentBalance)</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</section>

<section class="table-panel">
    <div class="panel-title"><h2>@T("Roadmap","خارطة الطريق")</h2><span class="badge bg-secondary-subtle text-secondary">@T("Upcoming releases","إصدارات قادمة")</span></div>
    <div class="roadmap-list">
        <span>POS</span>
        <span>ZATCA Phase 2</span>
        <span>@T("WhatsApp invoice delivery","إرسال الفواتير عبر WhatsApp")</span>
        <span>@T("AI accounting assistant","مساعد محاسبي بالذكاء الاصطناعي")</span>
        <span>@T("Approval workflows","سير اعتمادات")</span>
        <span>@T("Supplier price comparison","مقارنة أسعار الموردين")</span>
        <span>@T("Reorder suggestions","اقتراحات إعادة الطلب")</span>
        <span>@T("Report builder","منشئ التقارير")</span>
        <span>@T("Mobile app","تطبيق جوال")</span>
        <span>@T("Multi-company support","دعم متعدد الشركات")</span>
    </div>
</section>

@section Scripts {
    <script>
        (function () {
            const monthlyLabels = @Html.Raw(JsonSerializer.Serialize(monthlyLabels));
            const monthlySales = @Html.Raw(JsonSerializer.Serialize(monthlySales));
            const monthlyPurchases = @Html.Raw(JsonSerializer.Serialize(monthlyPurchases));
            const cashLabels = @Html.Raw(JsonSerializer.Serialize(cashLabels));
            const cashInflow = @Html.Raw(JsonSerializer.Serialize(cashInflow));
            const cashOutflow = @Html.Raw(JsonSerializer.Serialize(cashOutflow));
            const expenseLabels = @Html.Raw(JsonSerializer.Serialize(expenseLabels));
            const expenseValues = @Html.Raw(JsonSerializer.Serialize(expenseValues));
            const inventoryLabels = @Html.Raw(JsonSerializer.Serialize(inventoryLabels));
            const inventoryValues = @Html.Raw(JsonSerializer.Serialize(inventoryValues));

            const L = {
                sales: @Html.Raw(JsonSerializer.Serialize(T("Sales","المبيعات"))),
                purchases: @Html.Raw(JsonSerializer.Serialize(T("Purchases","المشتريات"))),
                inflow: @Html.Raw(JsonSerializer.Serialize(T("Cash In","تدفق داخل"))),
                outflow: @Html.Raw(JsonSerializer.Serialize(T("Cash Out","تدفق خارج"))),
                noData: @Html.Raw(JsonSerializer.Serialize(T("No data","لا يوجد بيانات")))
            };

            const palette = ["#5B5BD6", "#2563eb", "#0E7C86", "#B7791F", "#7C3AED", "#0284C7", "#DC3545", "#166D44"];
            const isRtl = document.documentElement.dir === "rtl";
            const fontFamily = getComputedStyle(document.body).fontFamily;
            const textMuted = "#6f6a59";
            const textStrong = "#1f1d18";
            const gridLine = "#ebe5d3";
            const isAr = document.documentElement.lang === "ar";

            const fmtNumber = (v) => {
                if (v == null || isNaN(v)) return "";
                const n = Number(v);
                if (Math.abs(n) >= 1_000_000) return (n / 1_000_000).toFixed(1) + "M";
                if (Math.abs(n) >= 1_000) return (n / 1_000).toFixed(1) + "K";
                return n.toLocaleString(isAr ? "ar-SA" : "en-US", { maximumFractionDigits: 0 });
            };
            const fmtMoney = (v) => isAr
                ? `${Number(v || 0).toLocaleString("ar-SA", { maximumFractionDigits: 0 })} ر.س`
                : `SAR ${Number(v || 0).toLocaleString("en-US", { maximumFractionDigits: 0 })}`;

            const baseTextStyle = { fontFamily, fontSize: 11, color: textMuted };
            const baseTooltip = {
                backgroundColor: "#ffffff",
                borderColor: "#ebe5d3",
                borderWidth: 1,
                textStyle: { fontFamily, fontSize: 12, color: textStrong },
                extraCssText: "box-shadow:0 8px 24px rgba(31,29,24,0.08); border-radius:8px;"
            };
            const baseLegend = {
                bottom: 6,
                icon: "roundRect",
                itemWidth: 10,
                itemHeight: 10,
                itemGap: 18,
                textStyle: baseTextStyle
            };

            const splitLabel = (value) => {
                if (typeof value !== "string") return value;
                const idx = value.lastIndexOf(" ");
                return idx > 0 ? value.slice(0, idx) + "\n" + value.slice(idx + 1) : value;
            };
            const categoryAxisLabel = {
                ...baseTextStyle,
                rotate: 0,
                interval: 0,
                hideOverlap: true,
                lineHeight: 14,
                formatter: splitLabel
            };

            const charts = [];
            function mount(id, option) {
                const el = document.getElementById(id);
                if (!el) return null;
                const chart = echarts.init(el, null, { renderer: "canvas" });
                chart.setOption(option);
                charts.push(chart);
                return chart;
            }

            mount("salesPurchasesChart", {
                color: ["#5B5BD6", "#2563EB"],
                textStyle: baseTextStyle,
                tooltip: {
                    ...baseTooltip, trigger: "axis",
                    valueFormatter: fmtMoney
                },
                legend: { ...baseLegend, data: [L.sales, L.purchases] },
                grid: { left: 14, right: 14, top: 22, bottom: 70, containLabel: true },
                xAxis: {
                    type: "category", data: monthlyLabels, boundaryGap: false, inverse: isRtl,
                    axisLine: { lineStyle: { color: gridLine } }, axisTick: { show: false },
                    axisLabel: categoryAxisLabel
                },
                yAxis: {
                    type: "value", position: isRtl ? "right" : "left",
                    splitLine: { lineStyle: { color: gridLine, type: "dashed" } },
                    axisLabel: { ...baseTextStyle, formatter: fmtNumber }
                },
                series: [
                    {
                        name: L.sales, type: "line", smooth: 0.4, showSymbol: false, data: monthlySales,
                        lineStyle: { width: 3, shadowColor: "rgba(91,91,214,0.25)", shadowBlur: 8, shadowOffsetY: 4 },
                        emphasis: { focus: "series" },
                        areaStyle: {
                            color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [
                                { offset: 0, color: "rgba(91,91,214,0.32)" },
                                { offset: 1, color: "rgba(91,91,214,0.0)" }
                            ])
                        }
                    },
                    {
                        name: L.purchases, type: "line", smooth: 0.4, showSymbol: false, data: monthlyPurchases,
                        lineStyle: { width: 3, shadowColor: "rgba(37,99,235,0.22)", shadowBlur: 8, shadowOffsetY: 4 },
                        emphasis: { focus: "series" },
                        areaStyle: {
                            color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [
                                { offset: 0, color: "rgba(37,99,235,0.24)" },
                                { offset: 1, color: "rgba(37,99,235,0.0)" }
                            ])
                        }
                    }
                ]
            });

            mount("cashFlowChart", {
                color: ["#166D44", "#B23B40"],
                textStyle: baseTextStyle,
                tooltip: {
                    ...baseTooltip, trigger: "axis",
                    axisPointer: { type: "shadow", shadowStyle: { color: "rgba(91,91,214,0.06)" } },
                    valueFormatter: fmtMoney
                },
                legend: { ...baseLegend, data: [L.inflow, L.outflow] },
                grid: { left: 14, right: 14, top: 22, bottom: 70, containLabel: true },
                xAxis: {
                    type: "category", data: cashLabels, inverse: isRtl,
                    axisLine: { lineStyle: { color: gridLine } }, axisTick: { show: false },
                    axisLabel: categoryAxisLabel
                },
                yAxis: {
                    type: "value", position: isRtl ? "right" : "left",
                    splitLine: { lineStyle: { color: gridLine, type: "dashed" } },
                    axisLabel: { ...baseTextStyle, formatter: fmtNumber }
                },
                series: [
                    {
                        name: L.inflow, type: "bar", data: cashInflow, barMaxWidth: 24,
                        itemStyle: {
                            borderRadius: [8, 8, 0, 0],
                            color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [
                                { offset: 0, color: "#1F8A56" },
                                { offset: 1, color: "#166D44" }
                            ])
                        },
                        emphasis: { itemStyle: { shadowColor: "rgba(22,109,68,0.25)", shadowBlur: 8 } }
                    },
                    {
                        name: L.outflow, type: "bar", data: cashOutflow, barMaxWidth: 24,
                        itemStyle: {
                            borderRadius: [8, 8, 0, 0],
                            color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [
                                { offset: 0, color: "#D45257" },
                                { offset: 1, color: "#B23B40" }
                            ])
                        },
                        emphasis: { itemStyle: { shadowColor: "rgba(178,59,64,0.25)", shadowBlur: 8 } }
                    }
                ]
            });

            const expenseDataset = (expenseLabels.length ? expenseLabels : [L.noData])
                .map((label, i) => ({ name: label, value: (expenseValues.length ? expenseValues[i] : 1) }));

            mount("expensesChart", {
                color: palette,
                textStyle: baseTextStyle,
                tooltip: {
                    ...baseTooltip, trigger: "item",
                    formatter: (p) => `${p.marker} <b>${p.name}</b><br/>${fmtMoney(p.value)} (${p.percent}%)`
                },
                legend: { ...baseLegend, type: "scroll", padding: [4, 16] },
                series: [{
                    type: "pie",
                    radius: ["52%", "78%"],
                    center: ["50%", "44%"],
                    avoidLabelOverlap: true,
                    itemStyle: {
                        borderColor: "#ffffff",
                        borderWidth: 3,
                        borderRadius: 6
                    },
                    label: { show: false },
                    labelLine: { show: false },
                    emphasis: {
                        scaleSize: 8,
                        itemStyle: { shadowBlur: 14, shadowColor: "rgba(31,29,24,0.18)" },
                        label: {
                            show: true, fontSize: 13, fontWeight: 700,
                            color: textStrong, fontFamily,
                            formatter: (p) => `${p.name}\n${p.percent}%`
                        }
                    },
                    data: expenseDataset
                }]
            });

            const invLabels = inventoryLabels.length ? inventoryLabels : [L.noData];
            const invValues = inventoryValues.length ? inventoryValues : [0];

            mount("inventoryChart", {
                textStyle: baseTextStyle,
                tooltip: {
                    ...baseTooltip, trigger: "axis",
                    axisPointer: { type: "shadow" },
                    valueFormatter: fmtMoney
                },
                grid: { left: 14, right: 36, top: 14, bottom: 28, containLabel: true },
                xAxis: {
                    type: "value", position: isRtl ? "top" : "bottom", inverse: isRtl,
                    splitLine: { lineStyle: { color: gridLine, type: "dashed" } },
                    axisLabel: { ...baseTextStyle, formatter: fmtNumber }
                },
                yAxis: {
                    type: "category", data: invLabels, inverse: true,
                    position: isRtl ? "right" : "left",
                    axisLine: { show: false }, axisTick: { show: false },
                    axisLabel: { ...baseTextStyle, color: textStrong, width: 110, overflow: "truncate", ellipsis: "…" }
                },
                series: [{
                    type: "bar",
                    data: invValues.map((v, i) => ({
                        value: v,
                        itemStyle: {
                            borderRadius: [0, 8, 8, 0],
                            color: new echarts.graphic.LinearGradient(0, 0, 1, 0, [
                                { offset: 0, color: palette[i % palette.length] + "AA" },
                                { offset: 1, color: palette[i % palette.length] }
                            ])
                        }
                    })),
                    label: {
                        show: true,
                        position: isRtl ? "insideLeft" : "right",
                        color: textStrong, fontFamily, fontSize: 11, fontWeight: 600,
                        formatter: (p) => fmtNumber(p.value)
                    },
                    barMaxWidth: 20
                }]
            });

            const resizeAll = () => charts.forEach(c => c && c.resize());
            window.addEventListener("resize", resizeAll);

            const shell = document.querySelector(".app-shell");
            if (shell && "MutationObserver" in window) {
                new MutationObserver(() => setTimeout(resizeAll, 450))
                    .observe(shell, { attributes: true, attributeFilter: ["class"] });
            }
        })();
    </script>
}

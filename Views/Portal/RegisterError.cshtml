@using System.Globalization
@{
    var isArabic = CultureInfo.CurrentUICulture.Name.StartsWith("ar", StringComparison.OrdinalIgnoreCase);
    string T(string en, string ar) => isArabic ? ar : en;
    ViewData["Title"] = T("Invitation invalid", "الدعوة غير صالحة");
    Layout = "_Layout";
}

<section class="portal-card" style="max-width:480px;margin:60px auto;text-align:center;">
    <i class="bi bi-exclamation-octagon" style="font-size:48px;color:#c92a2a;"></i>
    <h1 class="h4 mt-2">@T("This invitation link is no longer valid", "رابط الدعوة لم يعد صالحاً")</h1>
    <p class="text-muted">
        @if (ViewBag.Used == true) { @T("It has already been used.", "تم استخدامه مسبقاً.") }
        else if (ViewBag.Expired == true) { @T("It has expired.", "انتهت صلاحيته.") }
        else { @T("Ask the company to send you a new invitation.", "اطلب من الشركة إرسال دعوة جديدة.") }
    </p>
    <a asp-action="Login" class="btn btn-outline-secondary mt-2">@T("Back to sign in", "العودة لتسجيل الدخول")</a>
</section>

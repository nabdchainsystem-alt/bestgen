@using System.Globalization
@using Microsoft.AspNetCore.Identity
@inject SignInManager<bestgen.Models.ApplicationUser> SignInManager
@inject UserManager<bestgen.Models.ApplicationUser> UserManager
@{
    var culture = CultureInfo.CurrentUICulture.Name;
    var isArabic = culture.StartsWith("ar", StringComparison.OrdinalIgnoreCase);
    var dir = isArabic ? "rtl" : "ltr";
    var lang = isArabic ? "ar" : "en";
    string T(string en, string ar) => isArabic ? ar : en;
    var bootstrapHref = isArabic
        ? "https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css"
        : "https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css";

    var pageTitle = ViewData["Title"] as string ?? T("Customer Portal", "بوابة العملاء");

    bestgen.Models.ApplicationUser? me = null;
    if (SignInManager.IsSignedIn(User))
    {
        me = await UserManager.GetUserAsync(User);
    }
    var displayName = me?.FullName ?? me?.Email ?? T("Guest", "زائر");
    var initials = string.IsNullOrWhiteSpace(displayName) ? "?" : displayName.Trim()[..1].ToUpperInvariant();
}
<!DOCTYPE html>
<html lang="@lang" dir="@dir">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle · Bestgen</title>
    <link rel="icon" type="image/png" href="~/img/logo.png" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=IBM+Plex+Sans+Arabic:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="@bootstrapHref" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        :root {
            --navy: #1B2E4B;
            --secondary: #4A6E91;
            --tertiary: #94A3B8;
            --canvas: #F8FAFC;
            --surface: #ffffff;
            --border: #E5EAF2;
            --text: #0E1E37;
            --muted: #4A6E91;
        }
        body {
            font-family: @(isArabic ? "'IBM Plex Sans Arabic'" : "'Inter'"), system-ui, -apple-system, sans-serif;
            background: var(--canvas);
            color: var(--text);
            min-height: 100vh;
        }
        .portal-topbar {
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            padding: 14px 24px;
            display: flex; align-items: center; justify-content: space-between;
            position: sticky; top: 0; z-index: 100;
        }
        .portal-brand { display:flex;align-items:center;gap:10px;font-weight:700;color:var(--navy);text-decoration:none; }
        .portal-brand img { height:36px;width:36px;object-fit:contain; }
        .portal-nav { display:flex;gap:4px;flex-wrap:wrap; }
        .portal-nav a {
            padding:6px 14px;border-radius:8px;color:var(--text);text-decoration:none;font-weight:500;font-size:14px;
        }
        .portal-nav a.active, .portal-nav a:hover { background:var(--canvas);color:var(--navy); }
        .portal-user { display:flex;align-items:center;gap:10px; }
        .portal-avatar { width:34px;height:34px;border-radius:50%;background:var(--navy);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:600;font-size:14px; }
        .portal-shell { max-width: 1100px; margin: 28px auto; padding: 0 20px; }
        .portal-card { background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:22px;margin-bottom:18px; }
        .portal-stat {
            background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:18px;text-align:center;
        }
        .portal-stat .label { font-size:12px;color:var(--muted);text-transform:uppercase;letter-spacing:.04em; }
        .portal-stat .value { font-size:28px;font-weight:700;color:var(--navy);margin-top:6px; }
        .stat-grid { display:grid; grid-template-columns: repeat(auto-fit,minmax(200px,1fr));gap:12px;margin-bottom:18px; }
        .table { background:var(--surface); border-radius:10px; overflow:hidden; }
        .badge.status-issued { background:#fff7d6;color:#7a5b00; }
        .badge.status-paid { background:#e2f6e8;color:#166d44; }
        .badge.status-draft { background:#eef0f5;color:var(--muted); }
        .lang-chip {
            background:transparent;border:1px solid var(--border);border-radius:999px;padding:4px 12px;color:var(--muted);text-decoration:none;font-size:12px;
        }
    </style>
</head>
<body>
@if (SignInManager.IsSignedIn(User) && me?.CustomerId is not null)
{
    <header class="portal-topbar">
        <a class="portal-brand" asp-controller="Portal" asp-action="Index">
            <img src="~/img/logo.png" alt="Bestgen" />
            <span>@T("Customer Portal", "بوابة العملاء")</span>
        </a>
        <nav class="portal-nav">
            @{
                var ctrl = ViewContext.RouteData.Values["controller"]?.ToString();
                var act = ViewContext.RouteData.Values["action"]?.ToString();
                bool isAct(string a) => ctrl == "Portal" && string.Equals(act, a, StringComparison.OrdinalIgnoreCase);
            }
            <a asp-controller="Portal" asp-action="Index" class="@(isAct("Index") ? "active" : "")"><i class="bi bi-house"></i> @T("Home", "الرئيسية")</a>
            <a asp-controller="Portal" asp-action="Invoices" class="@(isAct("Invoices") || isAct("InvoiceDetail") ? "active" : "")"><i class="bi bi-file-earmark-text"></i> @T("Invoices", "الفواتير")</a>
            <a asp-controller="Portal" asp-action="Quotations" class="@(isAct("Quotations") || isAct("QuotationDetail") ? "active" : "")"><i class="bi bi-file-earmark-spreadsheet"></i> @T("Quotations", "عروض الأسعار")</a>
            <a asp-controller="Portal" asp-action="Profile" class="@(isAct("Profile") ? "active" : "")"><i class="bi bi-person"></i> @T("Profile", "الملف الشخصي")</a>
        </nav>
        <div class="portal-user">
            <a class="lang-chip" href="/Language/Set?culture=@(isArabic ? "en-US" : "ar-SA")&returnUrl=@(ViewContext.HttpContext.Request.Path)">@(isArabic ? "EN" : "AR")</a>
            <div class="portal-avatar">@initials</div>
            <span class="d-none d-md-inline" style="font-weight:600;font-size:14px;">@displayName</span>
            <form asp-controller="Portal" asp-action="Logout" method="post" class="m-0">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-sm btn-outline-secondary"><i class="bi bi-box-arrow-right"></i></button>
            </form>
        </div>
    </header>
}

<main class="portal-shell">
    @if (TempData["PortalMessage"] is string m)
    {
        <div class="alert alert-success"><i class="bi bi-check2-circle"></i> @m</div>
    }
    @RenderBody()
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>

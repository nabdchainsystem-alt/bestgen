@using System.Globalization
@model IReadOnlyList<bestgen.Services.GosiForEmployeeResult>
@{
    var isArabic = CultureInfo.CurrentUICulture.Name.StartsWith("ar", StringComparison.OrdinalIgnoreCase);
    string T(string en, string ar) => isArabic ? ar : en;
    ViewData["Title"] = T("GOSI Contributions", "اشتراكات التأمينات الاجتماعية");
}

<partial name="_PageHeader" model="@(new PageHeaderViewModel(
    T("GOSI Contributions (KSA)", "اشتراكات التأمينات الاجتماعية"),
    T("Monthly GOSI calculation per active employee. Saudi nationals: 11.75% employer + 10% employee. Non-Saudi: 2% employer only. Cap: SAR 45,000.",
      "احتساب التأمينات الاجتماعية الشهري لكل موظف نشط. للمواطنين: 11.75% صاحب العمل + 10% الموظف. لغير السعوديين: 2% صاحب العمل فقط. الحد الأعلى: 45,000 ريال."),
    null, null, null))" />

<section class="data-panel">
    @if (Model.Count == 0)
    {
        <p class="text-muted m-0">@T("No active employees.", "لا يوجد موظفون نشطون.")</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>@T("Employee", "الموظف")</th>
                        <th>@T("Saudi", "سعودي")</th>
                        <th class="text-end">@T("Contribution base", "أساس الاشتراك")</th>
                        <th class="text-end">@T("Employer share", "حصة صاحب العمل")</th>
                        <th class="text-end">@T("Employee share", "حصة الموظف")</th>
                        <th class="text-end">@T("Total", "الإجمالي")</th>
                    </tr>
                </thead>
                <tbody>
                @{ var totEmployer = 0m; var totEmployee = 0m; var totBase = 0m; }
                @foreach (var r in Model)
                {
                    totEmployer += r.Employer; totEmployee += r.Employee; totBase += r.ContributionBase;
                    <tr>
                        <td>@r.EmployeeId</td>
                        <td>@r.EmployeeName</td>
                        <td>@(r.IsSaudi ? T("Yes", "نعم") : T("No", "لا"))</td>
                        <td class="text-end">@r.ContributionBase.ToString("N2")</td>
                        <td class="text-end">@r.Employer.ToString("N2")</td>
                        <td class="text-end">@r.Employee.ToString("N2")</td>
                        <td class="text-end fw-bold">@r.Total.ToString("N2")</td>
                    </tr>
                }
                </tbody>
                <tfoot class="table-light">
                    <tr>
                        <th colspan="3" class="text-end">@T("Totals", "المجاميع")</th>
                        <th class="text-end">@totBase.ToString("N2")</th>
                        <th class="text-end">@totEmployer.ToString("N2")</th>
                        <th class="text-end">@totEmployee.ToString("N2")</th>
                        <th class="text-end">@((totEmployer + totEmployee).ToString("N2"))</th>
                    </tr>
                </tfoot>
            </table>
        </div>
    }
</section>

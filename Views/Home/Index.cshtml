                <div class="section-head">
                    <span class="section-eyebrow"><i class="bi bi-grid-3x3-gap-fill"></i> @Bi("Nine modules · One experience", "تسع وحدات · تجربة واحدة")</span>
                    <h2>@Bi("Everything your business needs", "كل ما تحتاجه أعمالك")</h2>
                    <p>@Bi("From the moment you make a sale to the moment you close the books, Bestgen walks beside you.", "من لحظة إتمام البيع إلى لحظة إقفال الدفاتر، يسير معك Bestgen خطوة بخطوة.")</p>

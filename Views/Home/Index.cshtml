@functions {
    Microsoft.AspNetCore.Html.HtmlString Bi(string en, string ar)
    {
        var enEsc = System.Net.WebUtility.HtmlEncode(en ?? string.Empty);
        var arEsc = System.Net.WebUtility.HtmlEncode(ar ?? string.Empty);
        return new Microsoft.AspNetCore.Html.HtmlString(
            $"<span class=\"i-en\">{enEsc}</span><span class=\"i-ar\">{arEsc}</span>");
    }
}
<!doctype html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Bestgen ERP — The all-in-one cloud ERP platform. Sales, purchasing, inventory, accounting, and HR unified in one bilingual experience built on .NET 8." />
    <meta name="theme-color" content="#0b1020" />
    <title>@ViewData["Title"]</title>

    <link rel="icon" type="image/png" href="/img/logo.png">
    <link rel="apple-touch-icon" href="/img/logo.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700;800&family=Cairo:wght@400;500;600;700;800&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/landing.css" asp-append-version="true" />
</head>
<body>
    <!-- Topbar -->
    <header class="topbar" id="topbar">
        <div class="topbar-inner container-x">
            <a class="brand" href="#top" aria-label="Bestgen ERP">
                <img src="/img/logo.png" alt="Bestgen ERP" class="brand-logo">
            </a>

            <nav class="topnav" aria-label="Main navigation">
                <a href="#features">@Bi("Features", "المميزات")</a>
                <a href="#preview">@Bi("Live Preview", "معاينة مباشرة")</a>
                <a href="#modules">@Bi("Modules", "الوحدات")</a>
                <a href="#reports">@Bi("Reports", "التقارير")</a>
                <a href="#pricing">@Bi("Pricing", "الأسعار")</a>
                <a href="#faq">@Bi("FAQ", "الأسئلة الشائعة")</a>
            </nav>

            <div class="topactions">
                <button class="btn btn-ghost lang-toggle" type="button" id="lang-toggle" aria-label="Switch language">
                    <i class="bi bi-translate"></i>
                    <span class="i-en">AR</span>
                    <span class="i-ar">EN</span>
                </button>
                <a class="btn btn-ghost" href="/Identity/Account/Login">
                    <i class="bi bi-box-arrow-in-right"></i>
                    <span>@Bi("Sign in", "تسجيل الدخول")</span>
                </a>
                <a class="btn btn-primary" href="/Identity/Account/Register">
                    <span>@Bi("Get started", "ابدأ الآن")</span>
                    <i class="bi bi-arrow-right"></i>
                </a>
            </div>

            <button class="mobile-toggle" type="button" aria-label="Menu" onclick="document.documentElement.classList.toggle('nav-open')">
                <i class="bi bi-list"></i>
            </button>
        </div>
        <div class="mobile-drawer">
            <a href="#features" onclick="document.documentElement.classList.remove('nav-open')">@Bi("Features", "المميزات")</a>
            <a href="#preview" onclick="document.documentElement.classList.remove('nav-open')">@Bi("Live Preview", "معاينة مباشرة")</a>
            <a href="#modules" onclick="document.documentElement.classList.remove('nav-open')">@Bi("Modules", "الوحدات")</a>
            <a href="#reports" onclick="document.documentElement.classList.remove('nav-open')">@Bi("Reports", "التقارير")</a>
            <a href="#pricing" onclick="document.documentElement.classList.remove('nav-open')">@Bi("Pricing", "الأسعار")</a>
            <a href="#faq" onclick="document.documentElement.classList.remove('nav-open')">@Bi("FAQ", "الأسئلة الشائعة")</a>
            <div class="mobile-actions">
                <button class="btn btn-ghost lang-toggle" type="button" id="lang-toggle-mobile" aria-label="Switch language">
                    <i class="bi bi-translate"></i>
                    <span class="i-en">العربية</span>
                    <span class="i-ar">English</span>
                </button>
                <a class="btn btn-ghost" href="/Identity/Account/Login">@Bi("Sign in", "تسجيل الدخول")</a>
                <a class="btn btn-primary" href="/Identity/Account/Register">@Bi("Get started", "ابدأ الآن")</a>
            </div>
        </div>
    </header>

    <main id="top">
        <!-- ============================================================ -->
        <!-- Hero                                                          -->
        <!-- ============================================================ -->
        <section class="hero">
            <div class="hero-bg" aria-hidden="true">
                <span class="blob blob-a"></span>
                <span class="blob blob-b"></span>
                <span class="blob blob-c"></span>
                <div class="hero-grid">
                    <svg width="100%" height="100%" preserveAspectRatio="xMidYMid slice">
                        <defs>
                            <pattern id="hero-dots" x="0" y="0" width="36" height="36" patternUnits="userSpaceOnUse">

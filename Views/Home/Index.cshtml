        <!-- Pricing                                                       -->
        <!-- ============================================================ -->
        <section class="pricing" id="pricing">
            <div class="container-x">
                <div class="section-head">
                    <span class="section-eyebrow"><i class="bi bi-tag-fill"></i> @Bi("Pricing", "الأسعار")</span>
                    <h2>@Bi("Transparent plans that grow with you", "باقات شفافة تنمو معك")</h2>
                    <p>@Bi("Start small, move up whenever you need to — without painful data migrations.", "ابدأ صغيراً، وارتقِ متى أردت — دون هجرات بيانات مؤلمة.")</p>
                    <div class="billing-toggle" role="tablist" aria-label="Billing period">
                        <button class="bt-option active" data-billing="month">@Bi("Monthly", "شهرياً")</button>
                        <button class="bt-option" data-billing="year">
                            @Bi("Yearly", "سنوياً")
                            <span class="bt-save">@Bi("save 20%", "وفر 20%")</span>
                        </button>
                    </div>
                </div>
                <div class="pricing-grid">
                    @foreach (var plan in pricing)
                    {
                        <article class="plan @(plan.Highlight ? "plan-featured" : "")">
                            @if (plan.Highlight)
                            {
                                <div class="plan-ribbon"><i class="bi bi-stars"></i> @Bi("Most popular", "الأكثر شعبية")</div>
                            }
                            <h3>@Bi(plan.NameEn, plan.NameAr)</h3>
                            <p class="plan-for">@Bi(plan.ForEn, plan.ForAr)</p>
                            <div class="plan-price">
                                <span class="currency">$</span>
                                <strong class="price-num"
                                        data-price-month="@plan.PriceMonth"
                                        data-price-year="@plan.PriceYear">@plan.PriceMonth</strong>
                                <span class="period">@Bi("/month", "/شهر")</span>
                            </div>
                            <p class="plan-billed">
                                <span class="i-en">Billed <span class="bill-period">monthly</span> · cancel anytime</span>
                                <span class="i-ar">فوترة <span class="bill-period">شهرية</span> · إلغاء في أي وقت</span>
                            </p>
                            <ul class="plan-features">
                                @for (var k = 0; k < plan.FeaturesEn.Length; k++)
                                {
                                    <li><i class="bi bi-check2-circle"></i><span>@Bi(plan.FeaturesEn[k], plan.FeaturesAr[k])</span></li>
                                }
                            </ul>
                            <a class="btn @(plan.Highlight ? "btn-primary" : "btn-outline") btn-block" href="/Identity/Account/Register">
                                <span>@Bi($"Choose {plan.NameEn}", $"اختر {plan.NameAr}")</span>
                                <i class="bi bi-arrow-right"></i>
                            </a>
                        </article>
                    }
                </div>
                <p class="pricing-note">
                    <i class="bi bi-shield-check"></i>
                    @Bi("All plans include automatic updates, daily backups, and bilingual support.", "تتضمن جميع الباقات تحديثات تلقائية ونسخاً احتياطية يومية ودعماً ثنائي اللغة.")
                </p>
            </div>
        </section>


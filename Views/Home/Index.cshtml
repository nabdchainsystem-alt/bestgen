                                <li><i class="dot dot-indigo"></i><span>@Bi("Tools", "أدوات")</span><strong>28%</strong></li>
                                <li><i class="dot dot-amber"></i><span>@Bi("Stationery", "قرطاسية")</span><strong>18%</strong></li>

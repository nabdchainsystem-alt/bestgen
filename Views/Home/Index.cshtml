    <script>
        // Language toggle (EN <-> AR). Persists choice in localStorage.
        (function () {
            var KEY = 'bestgen.lang';
            var html = document.documentElement;
            var titles = { en: 'Bestgen ERP — The all-in-one cloud ERP platform',
                            ar: 'Bestgen ERP — منصة ERP السحابية المتكاملة' };
            function apply(lang) {
                var isAr = (lang === 'ar');
                html.setAttribute('lang', isAr ? 'ar' : 'en');
                html.setAttribute('dir', isAr ? 'rtl' : 'ltr');
                document.title = titles[isAr ? 'ar' : 'en'];
            }
            var saved = null;
            try { saved = localStorage.getItem(KEY); } catch (e) {}
            if (saved === 'ar' || saved === 'en') apply(saved);
            function toggle() {
                var next = (html.getAttribute('dir') === 'rtl') ? 'en' : 'ar';
                apply(next);
                try { localStorage.setItem(KEY, next); } catch (e) {}
            }
            document.querySelectorAll('.lang-toggle').forEach(function (el) {
                el.addEventListener('click', function (e) { e.preventDefault(); toggle(); });
            });
        })();
    </script>

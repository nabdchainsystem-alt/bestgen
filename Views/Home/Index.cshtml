                            <h3>@Bi(m.TitleEn, m.TitleAr)</h3>
                            <p>@Bi(m.SubEn, m.SubAr)</p>
                            <ul class="module-list">
                                @for (var k = 0; k < m.ItemsEn.Length; k++)
                                {
                                    <li><i class="bi bi-check2"></i><span>@Bi(m.ItemsEn[k], m.ItemsAr[k])</span></li>
                                }
                            </ul>
                        </article>

        <!-- ============================================================ -->
        <!-- 3 Pillars                                                     -->
        <!-- ============================================================ -->
        <section class="pillars" id="features">
            <div class="container-x">
                <div class="section-head">
                    <span class="section-eyebrow"><i class="bi bi-diamond-half"></i> @Bi("Why Bestgen", "لماذا Bestgen")</span>

@using System.Globalization
@model JournalEntryFormViewModel
@{
    var isArabic = CultureInfo.CurrentUICulture.Name.StartsWith("ar", StringComparison.OrdinalIgnoreCase);
    string T(string en, string ar) => isArabic ? ar : en;
    ViewData["Title"] = T("Edit Journal Entry", "تعديل قيد يومية");
}

<partial name="_PageHeader" model="@(new PageHeaderViewModel(
    T("Edit Journal Entry", "تعديل قيد يومية"),
    T("Review the lines and save your changes.", "راجع أطراف القيد ثم احفظ التغييرات.")))" />

<section class="form-panel">
    <form asp-action="Edit" asp-route-id="@Model.Id" method="post" data-journal-form>
        <partial name="_Form" model="@Model" />
        <div class="d-flex gap-2 mt-4">
            <button class="btn btn-primary" type="submit"><i class="bi bi-check2"></i> @T("Save changes", "حفظ التغييرات")</button>
            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">@T("Cancel", "إلغاء")</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/journal-entry.js" asp-append-version="true"></script>
}

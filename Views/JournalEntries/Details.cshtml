@model JournalEntry
@{
    ViewData["Title"] = Model.EntryNumber;
}

<div class="page-header">
    <div>
        <h1>@Model.EntryNumber</h1>
        <p>@Model.EntryDate.ToString("yyyy/MM/dd") - @(Model.SourceModule ?? "قيد يدوي")</p>
    </div>
    <div class="d-flex gap-2 align-items-center">
        <partial name="_StatusBadge" model="@(new StatusBadgeViewModel(Model.Status))" />
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary"><i class="bi bi-pencil"></i> تعديل</a>
    </div>
</div>

<section class="details-panel">
    <div class="summary-grid">
        <div class="summary-card"><span>إجمالي المدين</span><strong>@EntityDisplayHelper.FormatValue(Model.TotalDebit, nameof(Model.TotalDebit))</strong></div>
        <div class="summary-card"><span>إجمالي الدائن</span><strong>@EntityDisplayHelper.FormatValue(Model.TotalCredit, nameof(Model.TotalCredit))</strong></div>
        <div class="summary-card"><span>الفرق</span><strong>@EntityDisplayHelper.FormatValue(Model.TotalDebit - Model.TotalCredit)</strong></div>
        <div class="summary-card"><span>المصدر</span><strong>@(Model.SourceModule ?? "-")</strong></div>
    </div>
    <p><strong>الوصف:</strong> @(Model.Description ?? "-")</p>
    <div class="table-responsive">
        <table class="table">
            <thead><tr><th>الحساب</th><th>الوصف</th><th>مدين</th><th>دائن</th></tr></thead>
            <tbody>
                @foreach (var line in Model.Lines)
                {
                    <tr>
                        <td>@line.Account?.AccountCode - @line.Account?.AccountNameAr</td>
                        <td>@(line.Description ?? "-")</td>
                        <td>@EntityDisplayHelper.FormatValue(line.Debit, nameof(line.Debit))</td>
                        <td>@EntityDisplayHelper.FormatValue(line.Credit, nameof(line.Credit))</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>

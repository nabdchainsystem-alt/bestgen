@using System.Globalization
@model JournalEntry
@{
    var isArabic = CultureInfo.CurrentUICulture.Name.StartsWith("ar", StringComparison.OrdinalIgnoreCase);
    string T(string en, string ar) => isArabic ? ar : en;
    string pickName(string ar, string? en) => isArabic ? ar : (string.IsNullOrWhiteSpace(en) ? ar : en!);
    ViewData["Title"] = Model.EntryNumber;
}

<div class="page-header">
    <div>
        <h1>@Model.EntryNumber</h1>
        <p>@Model.EntryDate.ToString("yyyy/MM/dd") - @(Model.SourceModule ?? T("Manual entry", "قيد يدوي"))</p>
    </div>
    <div class="d-flex gap-2 align-items-center">
        <partial name="_StatusBadge" model="@(new StatusBadgeViewModel(Model.Status))" />
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary"><i class="bi bi-pencil"></i> @T("Edit", "تعديل")</a>
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-@(isArabic ? "right" : "left")"></i> @T("Back to list", "العودة إلى القائمة")</a>
    </div>
</div>

<section class="details-panel">
    <div class="summary-grid">
        <div class="summary-card"><span>@T("Total debit", "إجمالي المدين")</span><strong>@EntityDisplayHelper.FormatValue(Model.TotalDebit, nameof(Model.TotalDebit))</strong></div>
        <div class="summary-card"><span>@T("Total credit", "إجمالي الدائن")</span><strong>@EntityDisplayHelper.FormatValue(Model.TotalCredit, nameof(Model.TotalCredit))</strong></div>
        <div class="summary-card"><span>@T("Difference", "الفرق")</span><strong>@EntityDisplayHelper.FormatValue(Model.TotalDebit - Model.TotalCredit)</strong></div>
        <div class="summary-card"><span>@T("Source", "المصدر")</span><strong>@(Model.SourceModule ?? "-")</strong></div>
    </div>
    <p><strong>@T("Description:", "الوصف:")</strong> @(Model.Description ?? "-")</p>
    <div class="table-responsive">
        <table class="table">
            <thead><tr><th>@T("Account", "الحساب")</th><th>@T("Description", "الوصف")</th><th>@T("Debit", "مدين")</th><th>@T("Credit", "دائن")</th></tr></thead>
            <tbody>
                @foreach (var line in Model.Lines)
                {
                    <tr>
                        <td>@line.Account?.AccountCode - @(line.Account == null ? "-" : pickName(line.Account.AccountNameAr, line.Account.AccountNameEn))</td>
                        <td>@(line.Description ?? "-")</td>
                        <td>@EntityDisplayHelper.FormatValue(line.Debit, nameof(line.Debit))</td>
                        <td>@EntityDisplayHelper.FormatValue(line.Credit, nameof(line.Credit))</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>

@using System.Globalization
@model IReadOnlyList<JournalEntry>
@{
    var isArabic = CultureInfo.CurrentUICulture.Name.StartsWith("ar", StringComparison.OrdinalIgnoreCase);
    string T(string en, string ar) => isArabic ? ar : en;
    ViewData["Title"] = T("Journal Entries", "القيود اليومية");
}

<partial name="_PageHeader" model="@(new PageHeaderViewModel(
    T("Journal Entries", "القيود اليومية"),
    T("Create and review accounting journal entries before posting.", "إنشاء ومراجعة القيود المحاسبية قبل الترحيل."),
    "Create", "JournalEntries", T("New entry", "قيد جديد")))" />

<section class="data-panel">
    <partial name="_SearchBar" />

    @if (!Model.Any())
    {
        <partial name="_EmptyState" model="@(T("No journal entries match the current filters.", "لا توجد قيود يومية مطابقة للفلاتر الحالية."))" />
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead><tr><th>@T("Entry No.", "رقم القيد")</th><th>@T("Date", "التاريخ")</th><th>@T("Source", "المصدر")</th><th>@T("Debit", "مدين")</th><th>@T("Credit", "دائن")</th><th>@T("Status", "الحالة")</th><th>@T("Actions", "الإجراءات")</th></tr></thead>
                <tbody>
                    @foreach (var entry in Model)
                    {
                        <tr>
                            <td>@entry.EntryNumber</td>
                            <td>@entry.EntryDate.ToString("yyyy/MM/dd")</td>
                            <td>@(entry.SourceModule ?? "-")</td>
                            <td>@EntityDisplayHelper.FormatValue(entry.TotalDebit, nameof(entry.TotalDebit))</td>
                            <td>@EntityDisplayHelper.FormatValue(entry.TotalCredit, nameof(entry.TotalCredit))</td>
                            <td><partial name="_StatusBadge" model="@(new StatusBadgeViewModel(entry.Status))" /></td>
                            <td><partial name="_ActionButtons" model="@entry.Id" /></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>

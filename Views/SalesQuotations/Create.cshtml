@using System.Globalization
@model SalesQuotationFormViewModel
@{
    var isArabic = CultureInfo.CurrentUICulture.Name.StartsWith("ar", StringComparison.OrdinalIgnoreCase);
    string T(string en, string ar) => isArabic ? ar : en;
    ViewData["Title"] = T("New Quotation", "عرض سعر جديد");
}

<partial name="_PageHeader" model="@(new PageHeaderViewModel(
    T("New Quotation", "عرض سعر جديد"),
    T("Build a quotation for the customer — totals and VAT compute live as you add items.", "أنشئ عرض سعر للعميل — تُحسب الضريبة والإجماليات تلقائياً مع كل صنف.")))" />

<section class="form-panel">
    <form asp-action="Create" method="post" data-invoice-form data-mode="sales">
        <partial name="_Form" model="@Model" />
        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary"><i class="bi bi-check2"></i> @T("Save quotation", "حفظ عرض السعر")</button>
            <a asp-action="Index" class="btn btn-outline-secondary">@T("Cancel", "إلغاء")</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/invoice.js" asp-append-version="true"></script>
}

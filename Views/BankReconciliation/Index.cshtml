@using System.Globalization
@using bestgen.Models
@{
    var isArabic = CultureInfo.CurrentUICulture.Name.StartsWith("ar", StringComparison.OrdinalIgnoreCase);
    string T(string en, string ar) => isArabic ? ar : en;
    ViewData["Title"] = T("Bank Reconciliation", "تسوية البنك");
    var statements = (List<BankStatement>)ViewBag.Statements;
    var accounts = (List<BankAccount>)ViewBag.BankAccounts;
}

<partial name="_PageHeader" model="@(new PageHeaderViewModel(
    T("Bank Reconciliation", "تسوية البنك"),
    T("Import a CSV statement from your bank, then match each line to its journal entry.",
      "استورد كشف الحساب من البنك بصيغة CSV، ثم طابق كل بند مع قيد اليومية المقابل."),
    null, null, null))" />

@if (TempData["BankMessage"] is string bm) { <div class="alert alert-success"><i class="bi bi-check2-circle"></i> @bm</div> }
@if (TempData["BankError"] is string be) { <div class="alert alert-danger"><i class="bi bi-exclamation-triangle"></i> @be</div> }

<section class="form-panel mb-3">
    <h3 class="h6">@T("Import statement", "استيراد كشف")</h3>
    <form asp-action="Import" method="post" enctype="multipart/form-data" class="row g-2 align-items-end">
        @Html.AntiForgeryToken()
        <div class="col-md-4">
            <label class="form-label small">@T("Bank account", "الحساب البنكي")</label>
            <select name="bankAccountId" class="form-select" required>
                @foreach (var a in accounts) { <option value="@a.Id">@a.AccountName (@a.BankName)</option> }
            </select>
        </div>
        <div class="col-md-6">
            <label class="form-label small">@T("CSV file", "ملف CSV")</label>
            <input type="file" name="file" accept=".csv,text/csv" class="form-control" required />
        </div>
        <div class="col-md-2 text-end">
            <button type="submit" class="btn btn-primary w-100"><i class="bi bi-upload"></i> @T("Import", "استيراد")</button>
        </div>
    </form>
    <small class="text-muted d-block mt-2">@T("Expected columns: Date, Description, Amount (or Debit + Credit), optional Balance + Reference. Headers in English or Arabic both work.",
                                              "الأعمدة المتوقعة: التاريخ، البيان، المبلغ (أو مدين + دائن)، اختياري: الرصيد والمرجع. يدعم الترويسات بالعربية والإنجليزية.")</small>
</section>

<section class="data-panel">
    <h3 class="h6">@T("Recent imports", "الواردات الأخيرة")</h3>
    @if (statements.Count == 0)
    {
        <p class="text-muted m-0">@T("No statements imported yet.", "لم يتم استيراد أي كشوفات بعد.")</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>@T("Imported", "تاريخ الاستيراد")</th>
                        <th>@T("Bank account", "الحساب")</th>
                        <th>@T("File", "الملف")</th>
                        <th class="text-center">@T("Lines", "البنود")</th>
                        <th>@T("Period", "الفترة")</th>
                        <th class="text-end">@T("Closing", "الرصيد الختامي")</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var s in statements)
                {
                    <tr>
                        <td>@s.ImportedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                        <td>@(s.BankAccount?.AccountName ?? "-")</td>
                        <td><code>@s.FileName</code></td>
                        <td class="text-center">@s.LineCount</td>
                        <td>@(s.PeriodStart?.ToString("yyyy-MM-dd"))–@(s.PeriodEnd?.ToString("yyyy-MM-dd"))</td>
                        <td class="text-end">@s.ClosingBalance.ToString("N2")</td>
                        <td><a asp-action="Detail" asp-route-id="@s.Id" class="btn btn-sm btn-outline-primary">@T("Open", "فتح")</a></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>

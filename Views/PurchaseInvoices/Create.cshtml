@model PurchaseInvoiceFormViewModel
@{
    ViewData["Title"] = "فاتورة شراء جديدة";
}

<partial name="_PageHeader" model="@(new PageHeaderViewModel("فاتورة شراء جديدة", "أضف بيانات المورد والأصناف وسيتم احتساب الضريبة والإجماليات تلقائيا."))" />

<section class="form-panel">
    <form asp-action="Create" method="post" data-invoice-form data-mode="purchase">
        <partial name="_Form" model="@Model" />
        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary"><i class="bi bi-check2"></i> حفظ الفاتورة</button>
            <a asp-action="Index" class="btn btn-outline-secondary">إلغاء</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/invoice.js" asp-append-version="true"></script>
}

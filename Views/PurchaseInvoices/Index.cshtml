@model IReadOnlyList<PurchaseInvoice>
@{
    ViewData["Title"] = "فواتير الشراء";
}

<partial name="_PageHeader" model="@(new PageHeaderViewModel("فواتير الشراء", "تسجيل مشتريات الموردين وتحديث المخزون والذمم.", "Create", "PurchaseInvoices", "فاتورة شراء جديدة"))" />

<section class="data-panel">
    <partial name="_SearchBar" />

    @if (!Model.Any())
    {
        <partial name="_EmptyState" model="@("لا توجد فواتير شراء مطابقة للفلاتر الحالية.")" />
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>رقم الفاتورة</th>
                        <th>مرجع المورد</th>
                        <th>التاريخ</th>
                        <th>المورد</th>
                        <th>الإجمالي</th>
                        <th>المتبقي</th>
                        <th>الحالة</th>
                        <th>الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var invoice in Model)
                    {
                        <tr>
                            <td>@invoice.PurchaseInvoiceNumber</td>
                            <td>@(invoice.SupplierInvoiceReference ?? "-")</td>
                            <td>@invoice.InvoiceDate.ToString("yyyy/MM/dd")</td>
                            <td>@invoice.Supplier?.NameAr</td>
                            <td>@EntityDisplayHelper.FormatValue(invoice.GrandTotal, nameof(invoice.GrandTotal))</td>
                            <td>@EntityDisplayHelper.FormatValue(invoice.RemainingAmount, nameof(invoice.RemainingAmount))</td>
                            <td><partial name="_StatusBadge" model="@(new StatusBadgeViewModel(invoice.Status))" /></td>
                            <td><partial name="_ActionButtons" model="@invoice.Id" /></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="text-muted small">ترقيم الصفحات placeholder للنسخة القادمة.</div>
    }
</section>

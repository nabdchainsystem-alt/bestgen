@using System.Globalization
@model PurchaseInvoiceFormViewModel
@{
    var isArabic = CultureInfo.CurrentUICulture.Name.StartsWith("ar", StringComparison.OrdinalIgnoreCase);
    string T(string en, string ar) => isArabic ? ar : en;
    string pickName(string ar, string? en) => isArabic ? ar : (string.IsNullOrWhiteSpace(en) ? ar : en!);

    var suppliers = ViewBag.Suppliers as List<Supplier> ?? new List<Supplier>();
    var warehouses = ViewBag.Warehouses as List<Warehouse> ?? new List<Warehouse>();
    var products = ViewBag.Products as List<Product> ?? new List<Product>();
    var paymentMethods = ViewBag.PaymentMethods as PaymentMethod[] ?? Array.Empty<PaymentMethod>();
    var statuses = ViewBag.Statuses as PurchaseInvoiceStatus[] ?? Array.Empty<PurchaseInvoiceStatus>();
    var invariant = CultureInfo.InvariantCulture;
    string number(decimal value) => value.ToString("0.##", invariant);
}

<div asp-validation-summary="All" class="form-validation-summary"></div>
<div class="form-section-title">@T("Invoice details", "بيانات الفاتورة")</div>
<div class="form-grid">
    <div>
        <label asp-for="PurchaseInvoiceNumber" class="form-label">@T("Invoice number", "رقم فاتورة الشراء")</label>
        <input asp-for="PurchaseInvoiceNumber" class="form-control" placeholder="@T("Auto on save", "تلقائي عند الحفظ")" />
        <span asp-validation-for="PurchaseInvoiceNumber" class="text-danger"></span>
    </div>
    <div>
        <label asp-for="SupplierInvoiceReference" class="form-label">@T("Supplier invoice reference", "مرجع فاتورة المورد")</label>
        <input asp-for="SupplierInvoiceReference" class="form-control" />
        <span asp-validation-for="SupplierInvoiceReference" class="text-danger"></span>
    </div>
    <div>
        <label asp-for="InvoiceDate" class="form-label">@T("Invoice date", "تاريخ الفاتورة")</label>
        <input asp-for="InvoiceDate" type="date" class="form-control" />
        <span asp-validation-for="InvoiceDate" class="text-danger"></span>
    </div>
    <div>
        <label asp-for="SupplierId" class="form-label">@T("Supplier", "المورد")</label>
        <select asp-for="SupplierId" class="form-select">
            <option value="">@T("Select supplier", "اختر المورد")</option>
            @foreach (var supplier in suppliers)
            {
                <option value="@supplier.Id">@supplier.SupplierCode - @pickName(supplier.NameAr, supplier.NameEn)</option>
            }
        </select>
        <span asp-validation-for="SupplierId" class="text-danger"></span>
    </div>
    <div>
        <label asp-for="WarehouseId" class="form-label">@T("Warehouse", "المستودع")</label>
        <select asp-for="WarehouseId" class="form-select">
            <option value="">@T("Select warehouse", "اختر المستودع")</option>
            @foreach (var warehouse in warehouses)
            {
                <option value="@warehouse.Id">@warehouse.Name</option>
            }
        </select>
        <span asp-validation-for="WarehouseId" class="text-danger"></span>
    </div>
    <div>
        <label asp-for="PaymentMethod" class="form-label">@T("Payment method", "طريقة الدفع")</label>
        <select asp-for="PaymentMethod" class="form-select">
            @foreach (var method in paymentMethods)
            {
                <option value="@method">@EntityDisplayHelper.TranslateEnum(method)</option>
            }
        </select>
    </div>
    <div>
        <label asp-for="Status" class="form-label">@T("Status", "الحالة")</label>
        <select asp-for="Status" class="form-select">
            @foreach (var status in statuses)
            {
                <option value="@status">@EntityDisplayHelper.TranslateEnum(status)</option>
            }
        </select>
    </div>
    <div class="full-width">
        <label asp-for="Notes" class="form-label">@T("Notes", "ملاحظات")</label>
        <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
        <span asp-validation-for="Notes" class="text-danger"></span>
    </div>
</div>

<div class="form-section-title mt-4">@T("Items", "الأصناف")</div>
<div class="table-responsive">
    <table class="table invoice-items">
        <thead>
            <tr>
                <th>@T("Item", "الصنف")</th>
                <th>@T("Qty", "الكمية")</th>
                <th>@T("Unit cost", "تكلفة الوحدة")</th>
                <th>@T("Discount", "الخصم")</th>
                <th>@T("VAT %", "الضريبة %")</th>
                <th>@T("Total", "الإجمالي")</th>
                <th></th>
            </tr>
        </thead>
        <tbody data-items-body>
            @for (var i = 0; i < Model.Items.Count; i++)
            {
                <tr data-item-row>
                    <td>
                        <select class="form-select js-product-select" name="Items[@i].ProductId">
                            <option value="">@T("Select item", "اختر الصنف")</option>
                            @foreach (var product in products)
                            {
                                if (product.Id == Model.Items[i].ProductId)
                                {
                                    <option value="@product.Id" data-selling-price="@number(product.SellingPrice)" data-purchase-price="@number(product.PurchasePrice)" data-vat="@number(product.VatRate)" selected>@product.SKU - @pickName(product.NameAr, product.NameEn)</option>
                                }
                                else
                                {
                                    <option value="@product.Id" data-selling-price="@number(product.SellingPrice)" data-purchase-price="@number(product.PurchasePrice)" data-vat="@number(product.VatRate)">@product.SKU - @pickName(product.NameAr, product.NameEn)</option>
                                }
                            }
                        </select>
                    </td>
                    <td><input class="form-control js-qty" name="Items[@i].Quantity" value="@number(Model.Items[i].Quantity)" type="number" step="0.01" min="0" /></td>
                    <td><input class="form-control js-unit" name="Items[@i].UnitCost" value="@number(Model.Items[i].UnitCost)" type="number" step="0.01" min="0" /></td>
                    <td><input class="form-control js-discount" name="Items[@i].Discount" value="@number(Model.Items[i].Discount)" type="number" step="0.01" min="0" /></td>
                    <td><input class="form-control js-vat" name="Items[@i].VatRate" value="@number(Model.Items[i].VatRate)" type="number" step="0.01" min="0" /></td>
                    <td><input class="form-control js-line-total" name="Items[@i].LineTotal" value="@number(Model.Items[i].LineTotal)" type="number" step="0.01" readonly /></td>
                    <td><button class="btn btn-light text-danger js-remove-row" type="button" title="@T("Remove", "حذف")"><i class="bi bi-trash"></i></button></td>
                </tr>
            }
        </tbody>
    </table>
</div>
<button class="btn btn-outline-primary" type="button" data-add-row><i class="bi bi-plus-lg"></i> @T("Add item", "إضافة صنف")</button>

<template data-row-template>
    <tr data-item-row>
        <td>
            <select class="form-select js-product-select" name="Items[__index__].ProductId">
                <option value="">@T("Select item", "اختر الصنف")</option>
                @foreach (var product in products)
                {
                    <option value="@product.Id" data-selling-price="@number(product.SellingPrice)" data-purchase-price="@number(product.PurchasePrice)" data-vat="@number(product.VatRate)">@product.SKU - @pickName(product.NameAr, product.NameEn)</option>
                }
            </select>
        </td>
        <td><input class="form-control js-qty" name="Items[__index__].Quantity" value="1" type="number" step="0.01" min="0" /></td>
        <td><input class="form-control js-unit" name="Items[__index__].UnitCost" value="0" type="number" step="0.01" min="0" /></td>
        <td><input class="form-control js-discount" name="Items[__index__].Discount" value="0" type="number" step="0.01" min="0" /></td>
        <td><input class="form-control js-vat" name="Items[__index__].VatRate" value="15" type="number" step="0.01" min="0" /></td>
        <td><input class="form-control js-line-total" name="Items[__index__].LineTotal" value="0" type="number" step="0.01" readonly /></td>
        <td><button class="btn btn-light text-danger js-remove-row" type="button" title="@T("Remove", "حذف")"><i class="bi bi-trash"></i></button></td>
    </tr>
</template>

<div class="totals-box mt-4">
    <div class="total-row"><span>@T("Subtotal (before VAT)", "الإجمالي قبل الضريبة")</span><strong data-total="subtotal">@Model.Subtotal.ToString("N2")</strong></div>
    <div class="total-row"><span>@T("Discounts", "الخصومات")</span><strong data-total="discount">@Model.DiscountTotal.ToString("N2")</strong></div>
    <div class="total-row"><span>@T("VAT", "ضريبة القيمة المضافة")</span><strong data-total="vat">@Model.VatTotal.ToString("N2")</strong></div>
    <div class="total-row grand"><span>@T("Grand total", "الإجمالي النهائي")</span><strong data-total="grand">@Model.GrandTotal.ToString("N2")</strong></div>
    <div class="mt-3">
        <label asp-for="PaidAmount" class="form-label">@T("Paid amount", "المبلغ المدفوع")</label>
        <input asp-for="PaidAmount" class="form-control js-paid" type="number" step="0.01" min="0" />
    </div>
    <div class="total-row"><span>@T("Outstanding", "المتبقي")</span><strong data-total="remaining">@Model.RemainingAmount.ToString("N2")</strong></div>
    <input asp-for="Subtotal" type="hidden" data-hidden-total="subtotal" />
    <input asp-for="DiscountTotal" type="hidden" data-hidden-total="discount" />
    <input asp-for="VatTotal" type="hidden" data-hidden-total="vat" />
    <input asp-for="GrandTotal" type="hidden" data-hidden-total="grand" />
    <input asp-for="RemainingAmount" type="hidden" data-hidden-total="remaining" />
</div>

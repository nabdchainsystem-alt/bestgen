@model PurchaseInvoiceFormViewModel
@{
    ViewData["Title"] = "تعديل فاتورة شراء";
}

<partial name="_PageHeader" model="@(new PageHeaderViewModel("تعديل فاتورة شراء", "راجع بيانات المورد والأصناف ثم احفظ التغييرات."))" />

<section class="form-panel">
    <form asp-action="Edit" asp-route-id="@Model.Id" method="post" data-invoice-form data-mode="purchase">
        <partial name="_Form" model="@Model" />
        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary"><i class="bi bi-check2"></i> حفظ التغييرات</button>
            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">إلغاء</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/invoice.js" asp-append-version="true"></script>
}

@model ReportCardViewModel
@{
    ViewData["Title"] = Model.Title;
}

<partial name="_PageHeader" model="@(new PageHeaderViewModel(Model.Title, Model.Description))" />

<section class="form-panel mb-4">
    <form method="get" class="list-toolbar" style="grid-template-columns:1fr 1fr 1fr auto auto auto;">
        <input type="hidden" name="id" value="@Model.ReportKey" />
        <div>
            <label class="form-label">من تاريخ</label>
            <input class="form-control" type="date" name="fromDate" value="@ViewBag.FromDate" />
        </div>
        <div>
            <label class="form-label">إلى تاريخ</label>
            <input class="form-control" type="date" name="toDate" value="@ViewBag.ToDate" />
        </div>
        <div>
            <label class="form-label">بحث</label>
            <input class="form-control" type="search" placeholder="بحث في التقرير..." />
        </div>
        <div class="d-flex align-items-end">
            <button class="btn btn-primary w-100" type="submit"><i class="bi bi-funnel"></i> تطبيق</button>
        </div>
        <div class="d-flex align-items-end">
            <button class="btn btn-outline-secondary w-100" type="button"><i class="bi bi-file-earmark-excel"></i> Excel</button>
        </div>
        <div class="d-flex align-items-end gap-2">
            <button class="btn btn-outline-secondary w-100" type="button"><i class="bi bi-file-earmark-pdf"></i> PDF</button>
            <button class="btn btn-outline-secondary" type="button" title="طباعة"><i class="bi bi-printer"></i></button>
        </div>
    </form>
</section>

<section class="details-panel">
    <div class="summary-grid">
        <div class="summary-card"><span>الفئة</span><strong>@Model.Category</strong></div>
        <div class="summary-card"><span>عدد السجلات</span><strong>0</strong></div>
        <div class="summary-card"><span>الفترة من</span><strong>@ViewBag.FromDate</strong></div>
        <div class="summary-card"><span>الفترة إلى</span><strong>@ViewBag.ToDate</strong></div>
    </div>

    <div class="panel-title">
        <h2>تفاصيل التقرير</h2>
        <span class="badge bg-secondary-subtle text-secondary">قيد التجهيز</span>
    </div>

    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <th>التاريخ</th>
                    <th>المرجع</th>
                    <th>الوصف</th>
                    <th>مدين</th>
                    <th>دائن</th>
                    <th>الرصيد</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td colspan="6">
                        <partial name="_EmptyState" model="@($"سيتم ربط تقرير «{Model.Title}» بقاعدة البيانات في المرحلة القادمة. الفلاتر والتصدير جاهزة للاستخدام.")" />
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="panel-title mt-4">
        <h2>خطة تطوير التقرير</h2>
        <span class="badge bg-blue-soft text-blue">Roadmap</span>
    </div>
    <div class="roadmap-list">
        <span>ربط مصادر البيانات</span>
        <span>تنسيق الأعمدة</span>
        <span>إجماليات أسبوعية وشهرية</span>
        <span>مقارنة الفترات</span>
        <span>تصدير Excel فعلي</span>
        <span>تصدير PDF فعلي</span>
        <span>طباعة محسنة</span>
        <span>حفظ كقالب مفضل</span>
    </div>
</section>
